@page "{id}"
@model fixflow.web.Pages.Tickets.DetailsModel
@{
    ViewData["Title"] = $"Ticket #{Model.Ticket.Id} - FixFlow";
    ViewData["HideNav"] = true;
}

<style>
    .details-shell {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .details-actions {
        display: inline-flex;
        gap: 8px;
        align-items: center;
    }

    .details-grid {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
        gap: 16px;
        align-items: start;
    }

    .details-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1.5rem;
        box-shadow: var(--shadow);
    }

    .details-card + .details-card {
        margin-top: 16px;
    }

    .ticket-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 1rem;
    }

    .ticket-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .meta-label {
        font-size: 0.7rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 600;
    }

    .meta-value {
        font-size: 0.95rem;
        color: var(--text);
        font-weight: 600;
    }

    .ticket-description {
        color: var(--muted);
        line-height: 1.6;
        padding: 1rem;
        background: var(--surface-2);
        border-radius: 10px;
        border: 1px solid var(--line);
    }

    .details-card .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--line);
    }

    .details-card .card-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }

    .comment {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 0.9rem 1rem;
        background: var(--surface-2);
        margin-bottom: 12px;
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 6px;
        color: var(--muted);
        font-size: 0.8rem;
    }

    .comment-author {
        font-weight: 600;
        color: var(--text);
    }

    .comment-badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: var(--bg-2);
        color: var(--accent-3);
        border: 1px solid var(--line);
        margin-left: 6px;
    }

    .comment-text {
        color: var(--text);
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .comment.internal {
        border-left: 3px solid var(--accent);
    }

    .comment-form {
        margin-top: 12px;
    }

    .comment-form textarea {
        width: 100%;
        min-height: 110px;
        resize: vertical;
    }

    .info-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        font-size: 0.9rem;
        color: var(--muted);
    }

    .info-label {
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .info-value {
        color: var(--text);
        font-weight: 600;
        text-align: right;
    }

    .timeline {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .timeline-item {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        background: var(--surface-2);
    }

    .timeline-title {
        font-weight: 600;
        color: var(--text);
        margin-bottom: 4px;
    }

    .timeline-details {
        font-size: 0.8rem;
        color: var(--muted);
    }

    .placeholder-banner {
        background: var(--surface-2);
        border: 1px dashed var(--line);
        color: var(--muted);
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.9rem;
    }

    @@media (max-width: 980px) {
        .details-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="details-shell">
            <div class="page-header">
                <div>
                    <h1 class="page-title">Ticket #@Model.Ticket.Id</h1>
                    <p class="page-subtitle">Details and updates for this request.</p>
                </div>
                <div class="details-actions">
                    <a href="/Tickets/List" class="btn btn-secondary">Back to Tickets</a>
                </div>
            </div>


            <div class="details-grid">
                <div>
                    <div class="details-card">
                        <div class="ticket-title">@Model.Ticket.Title</div>

                        <div class="ticket-meta">
                            <div class="meta-item">
                                <span class="meta-label">Status</span>
                                <span class="badge badge-@Model.Ticket.Status.ToLower().Replace(" ", "")">
                                    @Model.Ticket.Status
                                </span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Priority</span>
                                <span class="meta-value priority-@Model.Ticket.Priority.ToLower()">
                                    @Model.Ticket.Priority
                                </span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Category</span>
                                <span class="meta-value">@Model.Ticket.Category</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Location</span>
                                <span class="meta-value">@Model.Ticket.Building, Room @Model.Ticket.RoomNumber</span>
                            </div>
                        </div>

                        <div class="ticket-description">
                            <strong>Description:</strong><br />
                            @Model.Ticket.Description
                        </div>

                        @if (Model.UserRole != "Client" || Model.IsOwnTicket)
                        {
                            <div class="details-actions" style="margin-top: 1.5rem;">
                                @if (Model.UserRole == "Manager" && Model.Ticket.Status == "Submitted")
                                {
                                    <button class="btn btn-primary">Assign Technician</button>
                                    <button class="btn btn-secondary">Change Priority</button>
                                }
                                @if (Model.UserRole == "Technician" && Model.Ticket.Status == "Assigned")
                                {
                                    <button class="btn btn-primary">Start Work</button>
                                }
                                @if (Model.UserRole == "Technician" && Model.Ticket.Status == "In Progress")
                                {
                                    <button class="btn btn-primary">Mark Complete</button>
                                    <button class="btn btn-secondary">Put On Hold</button>
                                }
                                @if (Model.UserRole == "Client" && Model.IsOwnTicket && Model.Ticket.Status == "Completed")
                                {
                                    <button class="btn btn-primary">Confirm Resolved</button>
                                    <button class="btn btn-secondary">Reopen Ticket</button>
                                }
                                @if (Model.UserRole == "Admin")
                                {
                                    <button class="btn btn-secondary">Edit Ticket</button>
                                    <button class="btn btn-ghost">Delete Ticket</button>
                                }
                            </div>
                        }
                    </div>

                    <div class="details-card">
                        <div class="card-header">
                            <h3 class="card-title">Comments & Updates</h3>
                        </div>

                        @foreach (var comment in Model.PublicComments)
                        {
                            <div class="comment">
                                <div class="comment-header">
                                    <div class="comment-author">
                                        @comment.AuthorName
                                        @if (!string.IsNullOrEmpty(comment.AuthorRole) && Model.UserRole != "Client")
                                        {
                                            <span class="comment-badge">@comment.AuthorRole</span>
                                        }
                                    </div>
                                    <span>@comment.CreatedDate.ToString("MMM dd, yyyy h:mm tt")</span>
                                </div>
                                <div class="comment-text">@comment.Text</div>
                            </div>
                        }

                        @if (!Model.PublicComments.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">💬</div>
                                <p>No comments yet</p>
                            </div>
                        }

                        <div class="comment-form">
                            <form method="post" asp-page-handler="AddComment">
                                <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                                <div class="form-group">
                                    <label>Add a comment</label>
                                    <textarea name="commentText" placeholder="Type your message here..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Post Comment</button>
                            </form>
                        </div>
                    </div>

                    @if (Model.UserRole != "Client")
                    {
                        <div class="details-card">
                            <div class="card-header">
                                <h3 class="card-title">Internal Notes</h3>
                                <span style="font-size: 0.875rem; color: var(--muted);">Not visible to clients</span>
                            </div>

                            @foreach (var note in Model.InternalNotes)
                            {
                                <div class="comment internal">
                                    <div class="comment-header">
                                        <div class="comment-author">
                                            @note.AuthorName
                                            <span class="comment-badge">@note.AuthorRole</span>
                                        </div>
                                        <span>@note.CreatedDate.ToString("MMM dd, yyyy h:mm tt")</span>
                                    </div>
                                    <div class="comment-text">@note.Text</div>
                                </div>
                            }

                            @if (!Model.InternalNotes.Any())
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">📝</div>
                                    <p>No internal notes yet</p>
                                </div>
                            }

                            <div class="comment-form">
                                <form method="post" asp-page-handler="AddInternalNote">
                                    <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                                    <div class="form-group">
                                        <label>Add internal note</label>
                                        <textarea name="noteText" placeholder="This will only be visible to staff..." required></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-secondary">Add Note</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <div>
                    <div class="details-card">
                        <div class="card-header">
                            <h3 class="card-title">Ticket Information</h3>
                        </div>
                        <div class="info-list">
                            <div class="info-item">
                                <span class="info-label">Submitted By</span>
                                <span class="info-value">@Model.Ticket.SubmittedBy</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Created</span>
                                <span class="info-value">@((Model.Ticket.CreatedDate == DateTime.MinValue) ? "-" : Model.Ticket.CreatedDate.ToString("MMM dd, yyyy"))</span>
                            </div>
                            @if (Model.Ticket.AssignedTo != null)
                            {
                                <div class="info-item">
                                    <span class="info-label">Assigned To</span>
                                    <span class="info-value">@Model.Ticket.AssignedTo</span>
                                </div>
                            }
                            @if (Model.Ticket.DueDate != null)
                            {
                                <div class="info-item">
                                    <span class="info-label">Due Date</span>
                                    <span class="info-value">@Model.Ticket.DueDate?.ToString("MMM dd, yyyy")</span>
                                </div>
                            }
                            @if (Model.Ticket.CompletedDate != null)
                            {
                                <div class="info-item">
                                    <span class="info-label">Completed</span>
                                    <span class="info-value">@Model.Ticket.CompletedDate?.ToString("MMM dd, yyyy")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="details-card">
                        <div class="card-header">
                            <h3 class="card-title">Activity History</h3>
                        </div>
                        <div class="timeline">
                            @foreach (var activity in Model.ActivityHistory)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-title">@activity.Action</div>
                                    <div class="timeline-details">
                                        @activity.PerformedBy · @activity.Timestamp.ToString("MMM dd, h:mm tt")
                                    </div>
                                </div>
                            }

                            @if (!Model.ActivityHistory.Any())
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">🗂️</div>
                                    <p>No activity yet</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
