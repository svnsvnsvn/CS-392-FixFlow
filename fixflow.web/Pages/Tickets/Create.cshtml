@page
@model fixflow.web.Pages.Tickets.CreateModel
@{
    ViewData["Title"] = "Create Ticket";
    ViewData["HideNav"] = true;
    ViewData["ActiveNav"] = "Tickets";
    ViewData["BreadcrumbPath"] = "Operations";
    ViewData["BreadcrumbTitle"] = "Create Ticket";
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="main ref-main">
        @await Html.PartialAsync("_Topbar")
        <div class="ref-page">
            <div class="ph">
                <p class="ph-s">Log a maintenance request with the right details.</p>
                <a asp-page="./List" class="btn btn-s"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Tickets</a>
            </div>

            <div class="card mb20">
                <div class="ch"><span class="ct">Maintenance Request</span></div>
                <div class="cb">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        @if (Model.IsStaff)
                        {
                            <div class="fg">
                                <label class="flbl" asp-for="Input.ResidentId">Resident (optional)</label>
                                <select class="fsel" asp-for="Input.ResidentId" asp-items="Model.Residents">
                                    <option value="">-- Select Resident (Optional) --</option>
                                </select>
                                <span asp-validation-for="Input.ResidentId" class="text-danger"></span>
                            </div>
                        }

                        <div class="fgrid">
                            <div class="fg">
                                <label class="flbl" asp-for="Input.LocationCode">Building / Location</label>
                                <select class="fsel" asp-for="Input.LocationCode" asp-items="Model.Buildings">
                                    <option value="">-- Select Building --</option>
                                </select>
                                <span asp-validation-for="Input.LocationCode" class="text-danger"></span>
                            </div>
                            <div class="fg">
                                <label class="flbl" asp-for="Input.Unit">Unit Number</label>
                                <input class="finp" asp-for="Input.Unit" type="number" min="1" max="9999" placeholder="e.g., 412" />
                                <span asp-validation-for="Input.Unit" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="fgrid">
                            <div class="fg">
                                <label class="flbl" asp-for="Input.TicketTypeCode">Issue Type</label>
                                <select class="fsel" asp-for="Input.TicketTypeCode" asp-items="Model.TicketTypes">
                                    <option value="">-- Select Issue Type --</option>
                                </select>
                                <span asp-validation-for="Input.TicketTypeCode" class="text-danger"></span>
                            </div>
                            @if (Model.IsStaff)
                            {
                                <div class="fg">
                                    <label class="flbl" asp-for="Input.DueDate">Due Date</label>
                                    <input class="finp" asp-for="Input.DueDate" type="date" />
                                    <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                                </div>
                            }
                        </div>

                        <div class="fg">
                            <label class="flbl" asp-for="Input.Description">Description</label>
                            <textarea class="fta" asp-for="Input.Description" rows="6" placeholder="Describe the issue — when it started, any steps taken, severity."></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="ph cb-actions">
                            <button type="submit" class="btn btn-p"><i class="bi bi-send" aria-hidden="true"></i> Submit Ticket</button>
                            <a asp-page="./List" class="btn btn-s">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
