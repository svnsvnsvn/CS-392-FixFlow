@page
@model fixflow.web.Pages.Tickets.CreateModel
@{
    ViewData["Title"] = "Create Ticket";
    ViewData["HideNav"] = true;
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="page-shell">
            <div class="page-header">
                <h1 class="page-title">Create New Ticket</h1>
                <p class="page-subtitle">Log a maintenance request with the right details.</p>
            </div>

            <div class="card">
                <form method="post" class="form-stack">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    @if (Model.IsStaff)
                    {
                        <div class="form-group">
                            <label asp-for="Input.ResidentId">Resident</label>
                            <select asp-for="Input.ResidentId" asp-items="Model.Residents" class="form-control">
                                <option value="">-- Select Resident (Optional) --</option>
                            </select>
                            <span asp-validation-for="Input.ResidentId" class="text-danger"></span>
                            <small class="form-text text-muted">Leave empty to create on behalf of yourself</small>
                        </div>
                    }

                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="Input.LocationCode">Building/Location</label>
                            <select asp-for="Input.LocationCode" asp-items="Model.Buildings" class="form-control">
                                <option value="">-- Select Building --</option>
                            </select>
                            <span asp-validation-for="Input.LocationCode" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Input.Unit">Unit Number</label>
                            <input asp-for="Input.Unit" type="number" min="1" max="9999" class="form-control" placeholder="e.g., 412" />
                            <span asp-validation-for="Input.Unit" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="Input.TicketTypeCode">Issue Type</label>
                            <select asp-for="Input.TicketTypeCode" asp-items="Model.TicketTypes" class="form-control">
                                <option value="">-- Select Issue Type --</option>
                            </select>
                            <span asp-validation-for="Input.TicketTypeCode" class="text-danger"></span>
                        </div>

                        @if (Model.IsStaff)
                        {
                            <div class="form-group">
                                <label asp-for="Input.DueDate">Due Date</label>
                                <input asp-for="Input.DueDate" type="date" class="form-control" />
                                <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Description">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="6" 
                                  placeholder="Please describe the issue in detail. Include location specifics, what's happening, and when it started..."></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                        <small class="form-text text-muted">Provide as much detail as possible to help us resolve your issue quickly.</small>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Submit Ticket</button>
                        <a class="btn btn-secondary" asp-page="./List">Back to Tickets</a>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>
