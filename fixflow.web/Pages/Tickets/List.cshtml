@page
@model fixflow.web.Pages.Tickets.ListModel
@{
    ViewData["Title"] = "Tickets List";
    ViewData["HideNav"] = true;
}


@section Styles {
    <link rel="stylesheet" href="~/css/tickets.css" />
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="page-shell">
            <div class="page-header">
                <div>
                    <h1 class="page-title"><i class="bi bi-list-ul"></i> All Tickets</h1>
                    <p class="page-subtitle">Track, search, and manage maintenance requests.</p>
                </div>
                <div class="tickets-toolbar">
                    <a href="/Dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
                    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New Ticket</a>
                </div>
            </div>

            <div class="card">
                <div class="filter-bar">
                    <div class="filter-group">
                        <input class="filter-input" type="search" placeholder="Search tickets" aria-label="Search tickets" />
                        <select class="filter-select" aria-label="Filter by status">
                            <option selected>All statuses</option>
                            <option>Submitted</option>
                            <option>In Progress</option>
                            <option>Assigned</option>
                            <option>Completed</option>
                        </select>
                        <select class="filter-select" aria-label="Filter by priority">
                            <option selected>All priorities</option>
                            <option>High</option>
                            <option>Medium</option>
                            <option>Low</option>
                        </select>
                        <select class="filter-select" aria-label="Sort tickets">
                            <option selected>Sort: last updated</option>
                            <option>Sort: newest</option>
                            <option>Sort: oldest</option>
                            <option>Sort: priority</option>
                        </select>
                    </div>
                    <div class="filter-spacer"></div>
                    <div class="filter-group">
                        <button class="btn btn-ghost" type="button">Clear filters</button>
                    </div>
                </div>

                <div class="table-container">
                    @if (Model.Tickets != null && Model.Tickets.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Type</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Location</th>
                                    <th>Unit</th>
                                    <th>Requested By</th>
                                    <th>Assigned To</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.Tickets)
                                {
                                    var statusClass = (ticket.StatusCode?.StatusName ?? "").ToLower().Replace(" ", "");
                                    var priorityClass = (ticket.PriorityCode?.PriorityName ?? "").ToLower();

                                    <tr>
                                        <td><span class="ticket-id">@(string.IsNullOrWhiteSpace(ticket.TicketShortCode) ? ticket.TicketId.ToString() : ticket.TicketShortCode)</span></td>
                                        <td>@(ticket.TicketType?.TypeName ?? "-")</td>
                                        <td>
                                            <span class="priority-text @priorityClass">
                                                @(ticket.PriorityCode?.PriorityName ?? "-")
                                            </span>
                                        </td>
                                        <td>
                                            @{
                                                var statusIconMap = statusClass switch
                                                {
                                                    "submitted" => "bi-circle",
                                                    "inreview" => "bi-clock",
                                                    "assigned" => "bi-person-check",
                                                    "inprogress" => "bi-arrow-repeat",
                                                    "onhold" => "bi-pause-circle",
                                                    "completed" => "bi-check-circle",
                                                    "cancelled" => "bi-x-circle",
                                                    _ => "bi-circle-fill"
                                                };
                                            }
                                            <i class="status-icon bi @statusIconMap" title="@(ticket.StatusCode?.StatusName ?? "-")"></i>
                                        </td>
                                        <td>@(ticket.Building?.LocationName ?? "-")</td>
                                        <td>@ticket.Unit</td>
                                        <td>@(ticket.RequestedByUser == null ? ticket.RequestedBy : $"{ticket.RequestedByUser.FName} {ticket.RequestedByUser.LName}")</td>
                                        <td>@(Model.TicketAssignees.ContainsKey(ticket.TicketId) ? Model.TicketAssignees[ticket.TicketId] : "-")</td>
                                        <td style="display: flex; gap: 0.5rem; align-items: center;">
                                            <a href="/Tickets/Details/@(string.IsNullOrWhiteSpace(ticket.TicketShortCode) ? ticket.TicketId.ToString() : ticket.TicketShortCode)" class="btn btn-secondary btn-icon" aria-label="View ticket">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Employee") && ticket.StatusCode?.StatusName == "Submitted" && !Model.TicketAssignees.ContainsKey(ticket.TicketId))
                                            {
                                                <form method="post" asp-page-handler="PickUpTicket" asp-route-ticketId="@ticket.TicketId" style="display: inline;">
                                                    <button type="submit" class="btn btn-primary btn-icon" aria-label="Pick up ticket" title="Pick up ticket">
                                                        <i class="bi bi-hand-thumbs-up"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
                            <p>No tickets to display</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
</div>