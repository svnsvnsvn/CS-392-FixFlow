@page
@model fixflow.web.Pages.Tickets.ListModel
@{
    ViewData["Title"] = "Tickets List";
    ViewData["HideNav"] = true;
}


@section Styles {
    <link rel="stylesheet" href="~/css/tickets.css" />
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="page-shell">
            <div class="page-header">
                <div>
                    <h1 class="page-title"><i class="bi bi-list-ul"></i> All Tickets</h1>
                    <p class="page-subtitle">Track, search, and manage maintenance requests.</p>
                </div>
                <div class="tickets-toolbar">
                    <a href="/Dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
                    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New Ticket</a>
                </div>
            </div>

            <div class="card">
                <div class="filter-bar">
                    <div class="filter-group">
                        <input class="filter-input" id="listTicketSearch" type="search" placeholder="Search tickets" aria-label="Search tickets" />
                        <select class="filter-select" id="listTicketStatusFilter" aria-label="Filter by status">
                            <option value="all" selected>All statuses</option>
                            <option value="submitted">Submitted</option>
                            <option value="in progress">In Progress</option>
                            <option value="assigned">Assigned</option>
                            <option value="completed">Completed</option>
                        </select>
                        <select class="filter-select" id="listTicketPriorityFilter" aria-label="Filter by priority">
                            <option value="all" selected>All priorities</option>
                            <option value="high">High</option>
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                        </select>
                        <select class="filter-select" id="listTicketSort" aria-label="Sort tickets">
                            <option value="last-updated" selected>Sort: last updated</option>
                            <option value="newest">Sort: newest</option>
                            <option value="oldest">Sort: oldest</option>
                            <option value="priority">Sort: priority</option>
                        </select>
                    </div>
                    <div class="filter-spacer"></div>
                    <div class="filter-group">
                        <button class="btn btn-ghost" type="button" id="listTicketClearFilters">Clear filters</button>
                    </div>
                </div>

                <div class="table-container">
                    @if (Model.Tickets != null && Model.Tickets.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Type</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Location</th>
                                    <th>Unit</th>
                                    <th>Requested By</th>
                                    <th>Assigned To</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.Tickets)
                                {
                                    var statusClass = (ticket.StatusCode?.StatusName ?? "").ToLower().Replace(" ", "");
                                    var priorityClass = (ticket.PriorityCode?.PriorityName ?? "").ToLower();
                                    var statusName = ticket.StatusCode?.StatusName ?? "-";
                                    var priorityName = ticket.PriorityCode?.PriorityName ?? "-";
                                    var ticketCode = string.IsNullOrWhiteSpace(ticket.TicketShortCode) ? ticket.TicketId.ToString() : ticket.TicketShortCode;
                                    var ticketTypeName = ticket.TicketType?.TypeName ?? "-";
                                    var locationName = ticket.Building?.LocationName ?? "-";
                                    var requestedBy = ticket.RequestedByUser == null ? ticket.RequestedBy : $"{ticket.RequestedByUser.FName} {ticket.RequestedByUser.LName}";
                                    var assignedTo = Model.TicketAssignees.ContainsKey(ticket.TicketId) ? Model.TicketAssignees[ticket.TicketId] : "-";

                                    <tr class="list-ticket-row"
                                        data-ticket-id="@ticket.TicketId"
                                        data-ticket-code="@ticketCode"
                                        data-type="@ticketTypeName"
                                        data-priority="@priorityName.ToLower()"
                                        data-status="@statusName.ToLower()"
                                        data-location="@locationName"
                                        data-unit="@ticket.Unit"
                                        data-requested-by="@requestedBy"
                                        data-assigned-to="@assignedTo">
                                        <td><span class="ticket-id">@ticketCode</span></td>
                                        <td>@ticketTypeName</td>
                                        <td>
                                            <span class="priority-text @priorityClass">
                                                @priorityName
                                            </span>
                                        </td>
                                        <td>
                                            @{
                                                var statusIconMap = statusClass switch
                                                {
                                                    "submitted" => "bi-circle",
                                                    "inreview" => "bi-clock",
                                                    "assigned" => "bi-person-check",
                                                    "inprogress" => "bi-arrow-repeat",
                                                    "onhold" => "bi-pause-circle",
                                                    "completed" => "bi-check-circle",
                                                    "cancelled" => "bi-x-circle",
                                                    _ => "bi-circle-fill"
                                                };
                                            }
                                            <i class="status-icon bi @statusIconMap" title="@statusName"></i>
                                        </td>
                                        <td>@locationName</td>
                                        <td>@ticket.Unit</td>
                                        <td>@requestedBy</td>
                                        <td>@assignedTo</td>
                                        <td style="display: flex; gap: 0.5rem; align-items: center;">
                                            <a href="/Tickets/Details/@ticketCode" class="btn btn-secondary btn-icon" aria-label="View ticket">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Employee") && ticket.StatusCode?.StatusName == "Submitted" && !Model.TicketAssignees.ContainsKey(ticket.TicketId))
                                            {
                                                <form method="post" asp-page-handler="PickUpTicket" asp-route-ticketId="@ticket.TicketId" style="display: inline;">
                                                    <button type="submit" class="btn btn-primary btn-icon" aria-label="Pick up ticket" title="Pick up ticket">
                                                        <i class="bi bi-hand-thumbs-up"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
                            <p>No tickets to display</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    const listTicketSearch = document.getElementById("listTicketSearch");
    const listTicketStatusFilter = document.getElementById("listTicketStatusFilter");
    const listTicketPriorityFilter = document.getElementById("listTicketPriorityFilter");
    const listTicketSort = document.getElementById("listTicketSort");
    const listTicketClearFilters = document.getElementById("listTicketClearFilters");
    const listTicketsTableBody = document.querySelector(".table-container tbody");
    const listTicketRows = listTicketsTableBody ? Array.from(listTicketsTableBody.querySelectorAll(".list-ticket-row")) : [];

    const listPriorityWeight = {
        high: 3,
        medium: 2,
        low: 1
    };

    const applyListTicketFilters = () => {
        if (!listTicketRows.length) {
            return;
        }

        const searchValue = (listTicketSearch?.value ?? "").trim().toLowerCase();
        const statusValue = listTicketStatusFilter?.value ?? "all";
        const priorityValue = listTicketPriorityFilter?.value ?? "all";
        const sortValue = listTicketSort?.value ?? "last-updated";

        listTicketRows.forEach((row) => {
            const rowStatus = (row.getAttribute("data-status") ?? "").toLowerCase();
            const rowPriority = (row.getAttribute("data-priority") ?? "").toLowerCase();
            const searchable = [
                row.getAttribute("data-ticket-code") ?? "",
                row.getAttribute("data-type") ?? "",
                row.getAttribute("data-priority") ?? "",
                row.getAttribute("data-status") ?? "",
                row.getAttribute("data-location") ?? "",
                row.getAttribute("data-unit") ?? "",
                row.getAttribute("data-requested-by") ?? "",
                row.getAttribute("data-assigned-to") ?? ""
            ].join(" ").toLowerCase();

            const matchesSearch = !searchValue || searchable.includes(searchValue);
            const matchesStatus = statusValue === "all" || rowStatus === statusValue;
            const matchesPriority = priorityValue === "all" || rowPriority === priorityValue;

            row.style.display = matchesSearch && matchesStatus && matchesPriority ? "table-row" : "none";
        });

        const sortedRows = [...listTicketRows].sort((left, right) => {
            const leftId = Number(left.getAttribute("data-ticket-id") ?? 0);
            const rightId = Number(right.getAttribute("data-ticket-id") ?? 0);

            switch (sortValue) {
                case "newest":
                case "last-updated":
                    return rightId - leftId;
                case "oldest":
                    return leftId - rightId;
                case "priority": {
                    const leftPriority = listPriorityWeight[(left.getAttribute("data-priority") ?? "").toLowerCase()] ?? 0;
                    const rightPriority = listPriorityWeight[(right.getAttribute("data-priority") ?? "").toLowerCase()] ?? 0;
                    if (rightPriority !== leftPriority) {
                        return rightPriority - leftPriority;
                    }
                    return rightId - leftId;
                }
                default:
                    return 0;
            }
        });

        sortedRows.forEach((row) => listTicketsTableBody?.appendChild(row));
    };

    listTicketSearch?.addEventListener("input", applyListTicketFilters);
    listTicketStatusFilter?.addEventListener("change", applyListTicketFilters);
    listTicketPriorityFilter?.addEventListener("change", applyListTicketFilters);
    listTicketSort?.addEventListener("change", applyListTicketFilters);

    listTicketClearFilters?.addEventListener("click", () => {
        if (listTicketSearch) {
            listTicketSearch.value = "";
        }
        if (listTicketStatusFilter) {
            listTicketStatusFilter.value = "all";
        }
        if (listTicketPriorityFilter) {
            listTicketPriorityFilter.value = "all";
        }
        if (listTicketSort) {
            listTicketSort.value = "last-updated";
        }

        applyListTicketFilters();
    });

    applyListTicketFilters();
</script>