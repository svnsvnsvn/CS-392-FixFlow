@page
@model fixflow.web.Pages.Tickets.ListModel
@{
    var isOpsLead = User.IsInRole("Admin") || User.IsInRole("Manager");
    var isTechnician = User.IsInRole("Employee");
    ViewData["Title"] = isOpsLead ? "Operations - FixFlow" : (isTechnician ? "Workspace - FixFlow" : "Tickets List");
    ViewData["HideNav"] = true;
    ViewData["ActiveNav"] = "Tickets";
    ViewData["BreadcrumbPath"] = "Operations";
    ViewData["BreadcrumbTitle"] = "All Tickets";
    ViewData["TopbarCreateUrl"] = "/Tickets/Create";
    ViewData["TopbarSearch"] = false;
    var isStaff = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Employee");
    var listColScope = isStaff ? "list-staff" : "list-lite";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tickets.css" />
    @if (Model.ShowOperationsStats)
    {
        <link rel="stylesheet" href="~/css/dashboard.css" />
    }
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="main ref-main">
        @await Html.PartialAsync("_Topbar")
        <div class="ref-page tickets-hub">
            @if (Model.ShowOperationsStats)
            {
                <div class="tickets-hub-hero">
                    <div class="tickets-hub-hero-text">
                        <p class="tickets-hub-lead">Operations hub: every ticket in the system. Filter the table, then open a row for details.</p>
                    </div>
                    <a href="/Tickets/Create" class="btn btn-p tickets-hub-cta">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i> Create ticket
                    </a>
                </div>
                <div class="stat-row ref-stat-row">
                    <div class="sc">
                        <div class="sc-lbl">Open Tickets</div>
                        <div class="sc-val">@Model.TotalTickets</div>
                        <div class="sc-sub">Active across all buildings</div>
                    </div>
                    <div class="sc">
                        <div class="sc-lbl">Pending</div>
                        <div class="sc-val">@Model.PendingTickets</div>
                    </div>
                    <div class="sc">
                        <div class="sc-lbl">In Progress</div>
                        <div class="sc-val">@Model.InProgressTickets</div>
                    </div>
                    <div class="sc ac">
                        <div class="sc-lbl">Completed Today</div>
                        <div class="sc-val">@Model.CompletedToday</div>
                    </div>
                </div>
            }
            else if (Model.ShowTechnicianWorkspaceIntro)
            {
                <div class="tickets-hub-hero">
                    <div class="tickets-hub-hero-text">
                        <p class="tickets-hub-lead">Workspace: the full queue—pick up work, filter by status or priority, and open any row for details.</p>
                    </div>
                    <a href="/Tickets/Create" class="btn btn-p tickets-hub-cta">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i> Create ticket
                    </a>
                </div>
            }

            <div class="tickets-hub-filters">
                <div class="tickets-hub-filters-head">
                    <span class="tickets-hub-filters-title">Find tickets</span>
                </div>
                <div class="tickets-hub-filters-inner fbar">
                    <div class="ts-wrap">
                        <i class="bi bi-search" aria-hidden="true"></i>
                        <input class="fbar-inp" id="listTicketSearch" type="search" placeholder="Search ticket #, type, location, unit…" aria-label="Search tickets" />
                    </div>
                    <select class="fbar-sel" id="listTicketStatusFilter" aria-label="Filter by status">
                        <option value="all" selected>All statuses</option>
                        <option value="submitted">Submitted</option>
                        <option value="in progress">In Progress</option>
                        <option value="assigned">Assigned</option>
                        <option value="completed">Completed</option>
                    </select>
                    @if (isStaff)
                    {
                        <select class="fbar-sel" id="listTicketPriorityFilter" aria-label="Filter by priority">
                            <option value="all" selected>All priorities</option>
                            <option value="high">High</option>
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                        </select>
                    }
                    <select class="fbar-sel" id="listTicketSort" aria-label="Sort tickets">
                        <option value="last-updated" selected>Sort: last updated</option>
                        <option value="newest">Sort: newest</option>
                        <option value="oldest">Sort: oldest</option>
                        @if (isStaff)
                        {
                            <option value="priority">Sort: priority</option>
                        }
                    </select>
                    <button class="fbar-clear tickets-hub-filters-clear" type="button" id="listTicketClearFilters">Clear all</button>
                </div>
            </div>

            <div class="tsec tickets-hub-tsec">
                <div class="tsec-hd tickets-tsec-hd">
                    <span class="ph-s" id="listTicketCount"></span>
                    @if (Model.Tickets != null && Model.Tickets.Any())
                    {
                        <div class="tickets-hd-tools">
                            <div class="tickets-col-dropdown">
                                <button type="button" class="tickets-col-toggle" id="listTicketColumnsToggle" aria-expanded="false" aria-controls="listTicketColumnsPanel">Columns</button>
                                <div class="tickets-col-panel" id="listTicketColumnsPanel" hidden role="group" aria-label="Visible columns"></div>
                            </div>
                        </div>
                    }
                </div>
                @if (Model.Tickets != null && Model.Tickets.Any())
                {
                    <table class="ticket-data-table">
                        <thead>
                            <tr>
                                <th class="col-id" data-tcol="id">ID</th>
                                <th data-tcol="issue">Issue</th>
                                <th data-tcol="type">Type</th>
                                @if (isStaff)
                                {
                                    <th data-tcol="priority">Priority</th>
                                }
                                <th data-tcol="status">Status</th>
                                <th data-tcol="location">Location</th>
                                <th data-tcol="unit">Unit</th>
                                <th data-tcol="requestedBy">Requested By</th>
                                <th data-tcol="assignedTo">Assigned To</th>
                                <th class="col-actions" data-tcol="actions" aria-label="Actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.Tickets)
                            {
                                var statusName = ticket.StatusCode?.StatusName ?? "-";
                                var statusKey = (statusName ?? "").ToLower().Replace(" ", "");
                                var sdClass = statusKey switch
                                {
                                    "submitted" => "sd-submitted",
                                    "inprogress" => "sd-inprogress",
                                    "in progress" => "sd-inprogress",
                                    "assigned" => "sd-assigned",
                                    "completed" => "sd-completed",
                                    "cancelled" => "sd-cancelled",
                                    "closed" => "sd-cls",
                                    _ => "sd-o"
                                };
                                var priorityName = ticket.PriorityCode?.PriorityName ?? "-";
                                var priorityKey = (priorityName ?? "").ToLower();
                                var ticketCode = string.IsNullOrWhiteSpace(ticket.TicketShortCode) ? ticket.TicketId.ToString() : ticket.TicketShortCode;
                                var ticketTypeName = ticket.TicketType?.TypeName ?? "-";
                                var locationName = ticket.Building?.LocationName ?? "-";
                                var requestedBy = ticket.RequestedByUser == null ? ticket.RequestedBy : $"{ticket.RequestedByUser.FName} {ticket.RequestedByUser.LName}";
                                var assignedTo = Model.TicketAssignees.ContainsKey(ticket.TicketId) ? Model.TicketAssignees[ticket.TicketId] : "-";

                                <tr class="list-ticket-row"
                                    data-ticket-id="@ticket.TicketId"
                                    data-ticket-code="@ticketCode"
                                    data-type="@ticketTypeName"
                                    data-priority="@priorityKey"
                                    data-status="@statusName.ToLower()"
                                    data-location="@locationName"
                                    data-unit="@ticket.Unit"
                                    data-requested-by="@requestedBy"
                                    data-assigned-to="@assignedTo">
                                    <td data-tcol="id"><span class="tid">#@ticketCode</span></td>
                                    <td data-tcol="issue">
                                        <div class="tissue">@(string.IsNullOrWhiteSpace(ticket.TicketDescription) ? ticketTypeName : (ticket.TicketDescription.Length > 60 ? ticket.TicketDescription.Substring(0, 60) + "…" : ticket.TicketDescription))</div>
                                        <div class="tmeta">@ticketTypeName</div>
                                    </td>
                                    <td data-tcol="type">@ticketTypeName</td>
                                    @if (isStaff)
                                    {
                                        <td data-tcol="priority"><span class="pri @priorityKey">@priorityName</span></td>
                                    }
                                    <td data-tcol="status"><span class="sdot @sdClass">@statusName</span></td>
                                    <td data-tcol="location">@locationName</td>
                                    <td data-tcol="unit">@ticket.Unit</td>
                                    <td data-tcol="requestedBy">@requestedBy</td>
                                    <td data-tcol="assignedTo">@assignedTo</td>
                                    <td data-tcol="actions">
                                        <a href="/Tickets/Details/@ticketCode" class="act-btn" aria-label="View ticket" title="View ticket">
                                            <i class="bi bi-three-dots" aria-hidden="true"></i>
                                        </a>
                                        @if (User.IsInRole("Employee") && ticket.StatusCode?.StatusName == "Submitted" && !Model.TicketAssignees.ContainsKey(ticket.TicketId))
                                        {
                                            <form method="post" asp-page-handler="PickUpTicket" asp-route-ticketId="@ticket.TicketId" class="ref-inline-form">
                                                <button type="submit" class="btn btn-p btn-sm" aria-label="Pick up ticket" title="Pick up ticket">
                                                    <i class="bi bi-hand-thumbs-up" aria-hidden="true"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty">
                        <div class="empty-ico">
                            <i class="bi bi-inbox" aria-hidden="true"></i>
                        </div>
                        <div class="empty-t">No tickets to display</div>
                        <div class="empty-s">You haven't submitted any maintenance requests yet. When you do, they'll appear here.</div>
                        <a href="/Tickets/Create" class="create-btn">Create your first ticket</a>
                    </div>
                }
            </div>
        </div>
    </main>
</div>

<script src="~/js/ticketTableColumns.js"></script>
<script>
    const listTicketSearch = document.getElementById("listTicketSearch");
    const listTicketStatusFilter = document.getElementById("listTicketStatusFilter");
    const listTicketPriorityFilter = document.getElementById("listTicketPriorityFilter");
    const listTicketSort = document.getElementById("listTicketSort");
    const listTicketClearFilters = document.getElementById("listTicketClearFilters");
    const listTicketCountEl = document.getElementById("listTicketCount");
    const listTicketsTableBody = document.querySelector(".tsec tbody");
    const listTicketRows = listTicketsTableBody ? Array.from(listTicketsTableBody.querySelectorAll(".list-ticket-row")) : [];
    const hasPriorityFilter = !!listTicketPriorityFilter;

    const listPriorityWeight = { high: 3, medium: 2, low: 1 };

    const applyListTicketFilters = () => {
        if (!listTicketRows.length) {
            if (listTicketCountEl) listTicketCountEl.textContent = "0 results";
            return;
        }
        const searchValue = (listTicketSearch?.value ?? "").trim().toLowerCase();
        const statusValue = listTicketStatusFilter?.value ?? "all";
        const priorityValue = hasPriorityFilter ? (listTicketPriorityFilter?.value ?? "all") : "all";
        const sortValue = listTicketSort?.value ?? "last-updated";

        listTicketRows.forEach((row) => {
            const rowStatus = (row.getAttribute("data-status") ?? "").toLowerCase();
            const rowPriority = (row.getAttribute("data-priority") ?? "").toLowerCase();
            const searchable = [
                row.getAttribute("data-ticket-code") ?? "",
                row.getAttribute("data-type") ?? "",
                row.getAttribute("data-status") ?? "",
                row.getAttribute("data-location") ?? "",
                row.getAttribute("data-unit") ?? "",
                row.getAttribute("data-requested-by") ?? "",
                row.getAttribute("data-assigned-to") ?? ""
            ].join(" ").toLowerCase();
            if (hasPriorityFilter) searchable += " " + (row.getAttribute("data-priority") ?? "");
            const matchesSearch = !searchValue || searchable.includes(searchValue);
            const matchesStatus = statusValue === "all" || rowStatus === statusValue;
            const matchesPriority = !hasPriorityFilter || priorityValue === "all" || rowPriority === priorityValue;
            row.style.display = matchesSearch && matchesStatus && matchesPriority ? "table-row" : "none";
        });

        const visible = listTicketRows.filter(r => r.style.display !== "none");
        if (listTicketCountEl) listTicketCountEl.textContent = visible.length + " result" + (visible.length !== 1 ? "s" : "");

        const sortedRows = [...listTicketRows].sort((left, right) => {
            const leftId = Number(left.getAttribute("data-ticket-id") ?? 0);
            const rightId = Number(right.getAttribute("data-ticket-id") ?? 0);
            if (hasPriorityFilter && sortValue === "priority") {
                const lp = listPriorityWeight[(left.getAttribute("data-priority") ?? "").toLowerCase()] ?? 0;
                const rp = listPriorityWeight[(right.getAttribute("data-priority") ?? "").toLowerCase()] ?? 0;
                if (rp !== lp) return rp - lp;
                return rightId - leftId;
            }
            switch (sortValue) {
                case "newest":
                case "last-updated": return rightId - leftId;
                case "oldest": return leftId - rightId;
                default: return rightId - leftId;
            }
        });
        sortedRows.forEach((row) => listTicketsTableBody?.appendChild(row));
    };

    listTicketSearch?.addEventListener("input", applyListTicketFilters);
    listTicketStatusFilter?.addEventListener("change", applyListTicketFilters);
    if (listTicketPriorityFilter) listTicketPriorityFilter.addEventListener("change", applyListTicketFilters);
    listTicketSort?.addEventListener("change", applyListTicketFilters);
    listTicketClearFilters?.addEventListener("click", () => {
        if (listTicketSearch) listTicketSearch.value = "";
        if (listTicketStatusFilter) listTicketStatusFilter.value = "all";
        if (listTicketPriorityFilter) listTicketPriorityFilter.value = "all";
        if (listTicketSort) listTicketSort.value = "last-updated";
        applyListTicketFilters();
    });
    applyListTicketFilters();

    (function () {
        var table = document.querySelector('.tickets-hub-tsec table.ticket-data-table');
        var panel = document.getElementById('listTicketColumnsPanel');
        var toggle = document.getElementById('listTicketColumnsToggle');
        if (!table || !panel || !toggle) return;
        var cols;
        @if (isStaff)
        {
            <text>
        cols = [
            { key: 'id', label: 'ID', required: true },
            { key: 'issue', label: 'Issue' },
            { key: 'type', label: 'Type' },
            { key: 'priority', label: 'Priority' },
            { key: 'status', label: 'Status' },
            { key: 'location', label: 'Location' },
            { key: 'unit', label: 'Unit' },
            { key: 'requestedBy', label: 'Requested By' },
            { key: 'assignedTo', label: 'Assigned To' },
            { key: 'actions', label: 'Actions', required: true }
        ];
            </text>
        }
        else
        {
            <text>
        cols = [
            { key: 'id', label: 'ID', required: true },
            { key: 'issue', label: 'Issue' },
            { key: 'type', label: 'Type' },
            { key: 'status', label: 'Status' },
            { key: 'location', label: 'Location' },
            { key: 'unit', label: 'Unit' },
            { key: 'requestedBy', label: 'Requested By' },
            { key: 'assignedTo', label: 'Assigned To' },
            { key: 'actions', label: 'Actions', required: true }
        ];
            </text>
        }
        window.initTicketTableColumns({
            table: table,
            scope: '@listColScope',
            columns: cols,
            panelHost: panel,
            toggleBtn: toggle
        });
    })();
</script>
