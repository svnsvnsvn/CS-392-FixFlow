@page
@model fixflow.web.Pages.Admin.AdminUserToolsModel
@{
    ViewData["Title"] = "Admin User Tool";
    ViewData["HideNav"] = true;
    ViewData["ActiveNav"] = "AdminUserTool";
    ViewData["BreadcrumbPath"] = "People";
    ViewData["BreadcrumbTitle"] = "Residents & Staff";
}

<script src="~/js/UserSearch.js"></script>
<script src="~/js/UserSettings.js"></script>
<script>    
    document.addEventListener('DOMContentLoaded', function() 
    {
        InitalizeUserSearch("userQuery","searchResults","/Admin/AdminUserTools?handler=Search");
        InitalizeUserSettingsFetcher("SelectedUserId","/Admin/AdminUserTools?handler=UserSettings");
    });
</script>

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")
    <main class="main ref-main">
        @await Html.PartialAsync("_Topbar")
        <div class="ref-page">
            <div class="ph">
                <p class="ph-s">Assign roles to users and optionally force password reset.</p>
            </div>

            <a href="/Admin/Users" class="btn btn-s mb20">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Users
            </a>

            <div class="admin-user-tools">
                <div class="admin-user-tools-grid">
                    <!-- SEARCH BOX -->
                    <div class="admin-panel">
                        <div class="admin-panel-h">
                            <i class="bi bi-search" aria-hidden="true"></i>
                            <span>Find User</span>
                        </div>
                        <div class="form-group">
                            <label for="userQuery">Search by Name</label>
                            <input type="text"
                                   id="userQuery"
                                   class="admin-input"
                                   value="@Model.Query"
                                   placeholder="First and/or last name..." />
                        </div>

                        <div asp-validation-summary="All" class="error-text admin-validation"></div>
                    </div>

                    <!-- USER LIST + ROLE SETTINGS -->
                    <form method="post" class="admin-user-form">
                        <div class="admin-panel">
                            <div class="admin-panel-h">
                                <i class="bi bi-person-plus" aria-hidden="true"></i>
                                <span>Assign Role</span>
                            </div>

                            <div class="form-group">
                                <label for="SelectedUserId">Select User</label>
                                <select name="SelectedUserId" id="SelectedUserId" size="8" class="admin-select">
                                    <optgroup label="Search Results" id="searchResults"></optgroup>
                                </select>
                            </div>
                        </div>

                        <div class="admin-panel">
                            <div class="admin-panel-h">
                                <i class="bi bi-sliders" aria-hidden="true"></i>
                                <span>User Settings</span>
                            </div>

                            <div class="form-group">
                                <label>User Role</label>
                                <div class="admin-role-options">
                                    <label class="admin-role-option">
                                        Resident
                                        <input type="radio" name="SelectedUserRole" value="Resident" />
                                    </label>
                                    <label class="admin-role-option">
                                        Employee
                                        <input type="radio" name="SelectedUserRole" value="Employee" />
                                    </label>
                                    <label class="admin-role-option">
                                        Manager
                                        <input type="radio" name="SelectedUserRole" value="Manager" />
                                    </label>
                                    <label class="admin-role-option">
                                        Admin
                                        <input type="radio" name="SelectedUserRole" value="Admin" />
                                    </label>
                                </div>
                            </div>

                            <div class="form-group admin-checkbox-row">
                                <label class="admin-checkbox-label">
                                    <input type="checkbox" asp-for="ResetPassOnLogin" />
                                    Force password reset on next login
                                </label>
                            </div>

                            <div class="form-group admin-submit-row">
                                <button type="submit" class="btn btn-p">
                                    Save Changes
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
