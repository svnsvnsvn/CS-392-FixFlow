@page
@model fixflow.web.Pages.Admin.AdminUserToolsModel
@{
    ViewData["Title"] = "Admin User Tool";
}

<script src="~/js/UserSearch.js"></script>
<script src="~/js/UserSettings.js"></script>
<script>    
    document.addEventListener('DOMContentLoaded', function() 
    {
        InitalizeUserSearch("userQuery","searchResults","/Admin/AdminUserTools?handler=Search");
        InitalizeUserSettingsFetcher("SelectedUserId","/Admin/AdminUserTools?handler=UserSettings");
    });
</script>


<h2 style="text-align:center; margin-top:1rem;">Admin User Tool</h2>


<div class="profile-grid">

    <!-- -------------------------------------------------- -->
    <!-- SEARCH BOX -->
    <!-- -------------------------------------------------- -->
    <div class="profile-box grid-item">
        <h2>Find User</h2>
        <div class="form-group">
            <p>Search by Name:</p>
            <input type="text"
                    id="userQuery"
                    value="@Model.Query"
                    placeholder="First and/or last name..." />
        </div>
        <br /><br />
        <!-- VALIDATION SUMMARY -->
        <div asp-validation-summary="All" class="error-text" style="margin-top:1rem;"></div>
    </div>


    <!-- -------------------------------------------------- -->
    <!-- USER LIST BOX -->
    <!-- -------------------------------------------------- -->
    <div class="password-box grid-item">

        <h2>Assign Role</h2>

        <!-- USER LIST -->
        <div class="form-group">
            <p>Select User:</p>

            <select name="SelectedUserId"
                    id="SelectedUserId"
                    size="8"
                    style="width:100%; padding:0.625rem; background-color:var(--primary-bg-color); color:white; border:0.0625rem solid var(--border-bg); border-radius:0.25rem;">

                <optgroup label="Search Results" id="searchResults">
                        
                </optgroup>
            </select>
        </div>
    </div>

    <!-- -------------------------------------------------- -->
    <!-- USER ROLE AND SETTINGS BOX -->
    <!-- -------------------------------------------------- -->

    <form method="post">
        <div class="settings-box grid-item">
            <!-- ROLE SELECTION (Option 1 applied) -->
            <div class="form-group">
                <h2>User Settings</h2>
                <p>User Role:</p>

                <div style="display:flex; gap:1.5rem;">

                    <label style="display:flex; flex-direction:column; align-items:center; gap:0.5rem; margin:0;">
                        Clerk
                        <input type="radio" name="SelectedUserRole" value="Clerk" />
                    </label>

                    <label style="display:flex; flex-direction:column; align-items:center; gap:0.5rem; margin:0;">
                        Employee
                        <input type="radio" name="SelectedUserRole" value="Employee" />
                    </label>

                    <label style="display:flex; flex-direction:column; align-items:center; gap:0.5rem; margin:0;">
                        Manager
                        <input type="radio" name="SelectedUserRole" value="Manager" />
                    </label>

                    <label style="display:flex; flex-direction:column; align-items:center; gap:0.5rem; margin:0;">
                        Admin
                        <input type="radio" name="SelectedUserRole" value="Admin" />
                    </label>
                </div>
            </div>
            <br />
            <div class="form-group">
                <div style="display:flex; flex-direction:column; align-items:flex-start; gap:0.5rem;">
                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                    <input type="checkbox" asp-for="ResetPassOnLogin" />
                        Force password reset on next login
                    </label>

                    <button type="submit" class="btn-primary" style="margin-top:1rem;">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
