@page
@model fixflow.web.Pages.Admin.PriorityCodesModel
@{
    ViewData["Title"] = "Manage Priority Codes";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-exclamation-triangle"></i> Manage Priority Codes</h1>
        <p class="page-subtitle">Configure priority levels for ticket classification</p>
    </div>

    <div class="toolbar">
        <a href="/Dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        <a asp-page="./PriorityCodeCreate" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Priority Code
        </a>
    </div>

    <div class="card">
        @if (Model.PriorityCodes != null && Model.PriorityCodes.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i class="bi bi-hash"></i> Code</th>
                        <th><i class="bi bi-exclamation-triangle"></i> Priority Name</th>
                        <th><i class="bi bi-pencil-square"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{int i = 0;}
                    @foreach (var priority in Model.PriorityCodes)
                    {
                        <tr>
                            <td>@priority.PriorityCode</td>
                            <td>@priority.PriorityName</td>
                            <td>
                                @if (i == 0)
                                {
                                    <img src="~/icons/arrow-up-circle.svg" style="visibility:hidden" />
                                }
                                else
                                {
                                    <a asp-page-handler="Decreasepriority" asp-route-id="@priority.Id">
                                        <img src="~/icons/arrow-up-circle.svg" />
                                    </a>
                                }
                                @if (i == Model.PriorityCodes.Count() - 1)
                                {
                                    <img src="~/icons/arrow-down-circle.svg" style="visibility:hidden" />
                                }
                                else
                                {
                                    <a asp-page-handler="Increasepriority" asp-route-id="@priority.Id">
                                        <img src="~/icons/arrow-down-circle.svg" />
                                    </a>
                                }
                                <a asp-page-handler="Deletepriority" asp-route-id="@priority.Id">
                                    <img src="~/icons/trash-2.svg" />
                                </a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i class="bi bi-exclamation-triangle icon-lg icon-faded"></i>
                <p>No priority codes configured yet. Click "Add New Priority Code" to get started.</p>
            </div>
        }
    </div>
</div>