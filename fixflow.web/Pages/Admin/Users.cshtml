@page
@model fixflow.web.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i data-lucide="users"></i> Manage Users</h1>
        <p class="page-subtitle">View and manage system users</p>
    </div>

    <div class="toolbar">
        <div></div>
        <a asp-page="/Account/NewUser" class="btn btn-primary">
            <i data-lucide="user-plus"></i> Add New User
        </a>
    </div>

    <div class="card">
        @if (Model.Users != null && Model.Users.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i data-lucide="user"></i> Name</th>
                        <th><i data-lucide="mail"></i> Email</th>
                        <th><i data-lucide="phone"></i> Phone</th>
                        <th><i data-lucide="map-pin"></i> Location</th>
                        <th><i data-lucide="edit"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FName @user.LName</td>
                            <td>@user.FfUser?.Email</td>
                            <td>@user.FfUser?.PhoneNumber</td>
                            <td>@user.Location</td>
                            <td>
                                <a href="#" class="btn btn-ghost"><i data-lucide="pencil"></i> Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i data-lucide="users" class="icon-lg icon-faded"></i>
                <p>No users found. Click "Add New User" to get started.</p>
            </div>
        }
    </div>
</div>