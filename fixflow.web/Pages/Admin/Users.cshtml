page
@model fixflow.web.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-people"></i> Manage Users</h1>
        <p class="page-subtitle">View and manage system users</p>
    </div>

    <div class="toolbar">
        <div></div>
        <a asp-page="/Account/NewUser" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Add New User
        </a>
    </div>

    <div class="card">
        @if (Model.Users != null && Model.Users.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i class="bi bi-person"></i> Name</th>
                        <th><i class="bi bi-envelope"></i> Email</th>
                        <th><i class="bi bi-telephone"></i> Phone</th>
                        <th><i class="bi bi-geo-alt"></i> Location</th>
                        <th><i class="bi bi-pencil-square"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FName @user.LName</td>
                            <td>@user.FfUser?.Email</td>
                            <td>@user.FfUser?.PhoneNumber</td>
                            <td>@user.Location</td>
                            <td>
                                <a href="#" class="btn btn-ghost"><i class="bi bi-pencil"></i> Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i class="bi bi-people icon-lg icon-faded"></i>
                <p>No users found. Click "Add New User" to get started.</p>
            </div>
        }
    </div>
</div>