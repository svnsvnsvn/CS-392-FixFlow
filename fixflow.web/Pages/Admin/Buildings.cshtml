@page
@model fixflow.web.Pages.Admin.BuildingsModel
@{
    ViewData["Title"] = "Manage Buildings";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i data-lucide="building"></i> Manage Buildings</h1>
        <p class="page-subtitle">Configure building locations for maintenance requests</p>
    </div>

    <div class="toolbar">
        <div></div>
        <a asp-page="./BuildingCreate" class="btn btn-primary">
            <i data-lucide="plus-circle"></i> Add New Building
        </a>
    </div>

    <div class="card">
        @if (Model.Buildings != null && Model.Buildings.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i data-lucide="hash"></i> Code</th>
                        <th><i data-lucide="building"></i> Location Name</th>
                        <th><i data-lucide="building-2"></i> Complex</th>
                        <th><i data-lucide="hash"></i> Building #</th>
                        <th><i data-lucide="door-closed"></i> Units</th>
                        <th><i data-lucide="edit"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var building in Model.Buildings)
                    {
                        <tr>
                            <td>@building.LocationCode</td>
                            <td>@building.LocationName</td>
                            <td>@building.ComplexName</td>
                            <td>@building.BuildingNumber</td>
                            <td>@building.NumUnits</td>
                            <td>
                                <a href="#" class="btn btn-ghost"><i data-lucide="pencil"></i> Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i data-lucide="building" class="icon-lg icon-faded"></i>
                <p>No buildings configured yet. Click "Add New Building" to get started.</p>
            </div>
        }
    </div>
</div>