@page
@model fixflow.web.Pages.Admin.BuildingsModel
@{
    ViewData["Title"] = "Manage Buildings";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-building"></i> Manage Buildings</h1>
        <p class="page-subtitle">Configure building locations for maintenance requests</p>
    </div>

    <div class="toolbar">
        <a href="/Dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        <a asp-page="./BuildingCreate" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Building
        </a>
    </div>

    <div class="card">
        @if (Model.Buildings != null && Model.Buildings.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i class="bi bi-buildings"></i> Complex Name</th>
                        <th><i class="bi bi-building"></i> Building Name</th>
                        <th><i class="bi bi-hash"></i> Building #</th>
                        <th><i class="bi bi-door-closed"></i> Units</th>
                        <th><i class="bi bi-pencil-square"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var building in Model.Buildings)
                    {
                        <tr>
                            <td>@building.ComplexName</td>
                            <td>@building.LocationName</td>
                            <td>@building.BuildingNumber</td>
                            <td>@building.NumUnits</td>
                            <td>
                                <a href="#" class="btn btn-ghost"><i class="bi bi-pencil"></i> Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i class="bi bi-building icon-lg icon-faded"></i>
                <p>No buildings configured yet. Click "Add New Building" to get started.</p>
            </div>
        }
    </div>
</div>