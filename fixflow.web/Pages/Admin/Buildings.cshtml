@page
@model fixflow.web.Pages.Admin.BuildingsModel
@{
    ViewData["Title"] = "Manage Buildings";
    ViewData["HideNav"] = true;
    ViewData["ActiveNav"] = "Buildings";
    ViewData["BreadcrumbPath"] = "Configuration";
    ViewData["BreadcrumbTitle"] = "Building Params";
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="main ref-main">
        @await Html.PartialAsync("_Topbar")
        <div class="ref-page">
            <div class="ph">
                <p class="ph-s">Configure building locations for maintenance requests.</p>
                <a asp-page="./BuildingCreate" class="btn btn-p">
                    <i class="bi bi-plus-circle" aria-hidden="true"></i> Add Building
                </a>
            </div>
            <a href="/Tickets/List" class="btn btn-s mb20">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Tickets
            </a>

            <div class="tsec">
                @if (Model.Buildings != null && Model.Buildings.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Complex Name</th>
                                <th>Building Name</th>
                                <th>Building #</th>
                                <th>Units</th>
                                <th class="col-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var building in Model.Buildings)
                            {
                                <tr>
                                    <td>@building.ComplexName</td>
                                    <td class="tissue">@building.LocationName</td>
                                    <td>@building.BuildingNumber</td>
                                    <td>@building.NumUnits</td>
                                    <td>
                                        <a href="#" class="btn btn-s btn-sm">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty">
                        <div class="empty-ico"><i class="bi bi-building" aria-hidden="true"></i></div>
                        <div class="empty-t">No buildings configured yet.</div>
                        <div class="empty-s">Click "Add Building" to get started.</div>
                        <a asp-page="./BuildingCreate" class="create-btn">Add Building</a>
                    </div>
                }
            </div>
        </div>
    </main>
</div>
