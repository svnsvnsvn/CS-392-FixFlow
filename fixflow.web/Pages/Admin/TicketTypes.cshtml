@page
@model fixflow.web.Pages.Admin.TicketTypesModel
@{
    ViewData["Title"] = "Manage Ticket Types";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i data-lucide="folder"></i> Manage Ticket Types</h1>
        <p class="page-subtitle">Configure categories for maintenance requests</p>
    </div>

    <div class="toolbar">
        <div></div>
        <a asp-page="./TicketTypeCreate" class="btn btn-primary">
            <i data-lucide="plus-circle"></i> Add New Ticket Type
        </a>
    </div>

    <div class="card">
        @if (Model.TicketTypes != null && Model.TicketTypes.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i data-lucide="hash"></i> Code</th>
                        <th><i data-lucide="folder"></i> Type Name</th>
                        <th><i data-lucide="edit"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticketType in Model.TicketTypes)
                    {
                        <tr>
                            <td>@ticketType.Code</td>
                            <td>@ticketType.TypeName</td>
                            <td>
                                <a href="#" class="btn btn-ghost"><i data-lucide="pencil"></i> Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i data-lucide="folder" class="icon-lg icon-faded"></i>
                <p>No ticket types configured yet. Click "Add New Ticket Type" to get started.</p>
            </div>
        }
    </div>
</div>