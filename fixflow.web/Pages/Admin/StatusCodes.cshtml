@page
@model fixflow.web.Pages.Admin.StatusCodesModel
@{
    ViewData["Title"] = "Manage Status Codes";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-flag"></i> Manage Status Codes</h1>
        <p class="page-subtitle">Configure status options for ticket workflow</p>
    </div>

    <div class="toolbar">
        <a href="/Dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        <a asp-page="./StatusCodeCreate" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Status Code
        </a>
    </div>

    <div class="card">
        @if (Model.StatusCodes != null && Model.StatusCodes.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i class="bi bi-hash"></i> Code</th>
                        <th><i class="bi bi-flag"></i> Status Name</th>
                        <th><i class="bi bi-pencil-square"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{int i = 0;}
                    @foreach (var status in Model.StatusCodes)
                    {
                        <tr>
                            <td>@status.StatusCode</td>
                            <td>@status.StatusName</td>
                            <td>
                                @if (i == 0)
                                {
                                    <img src="~/icons/arrow-up-circle.svg" style="visibility:hidden" />
                                }
                                else
                                {
                                    <a asp-page-handler="DecreaseStatus"  asp-route-id="@status.Id">
                                        <img src="~/icons/arrow-up-circle.svg" /></a>
                                }
                                @if (i == Model.StatusCodes.Count() - 1)
                                {
                                    <img src="~/icons/arrow-down-circle.svg" style="visibility:hidden"/>
                                }
                                else
                                {
                                    <a asp-page-handler="IncreaseStatus" asp-route-id="@status.Id">
                                        <img src="~/icons/arrow-down-circle.svg" /></a>
                                }
                                <a asp-page-handler="DeleteStatus" asp-route-id="@status.Id">
                                    <img src="~/icons/trash-2.svg" /></a>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i class="bi bi-flag icon-lg icon-faded"></i>
                <p>No status codes configured yet. Click "Add New Status Code" to get started.</p>
            </div>
        }
    </div>
</div>