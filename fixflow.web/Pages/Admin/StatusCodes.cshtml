@page
@model fixflow.web.Pages.Admin.StatusCodesModel
@{
    ViewData["Title"] = "Manage Status Codes";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i data-lucide="flag"></i> Manage Status Codes</h1>
        <p class="page-subtitle">Configure status options for ticket workflow</p>
    </div>

    <div class="toolbar">
        <div></div>
        <a asp-page="./StatusCodeCreate" class="btn btn-primary">
            <i data-lucide="plus-circle"></i> Add New Status Code
        </a>
    </div>

    <div class="card">
        @if (Model.StatusCodes != null && Model.StatusCodes.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th><i data-lucide="hash"></i> Code</th>
                        <th><i data-lucide="flag"></i> Status Name</th>
                        <th><i data-lucide="edit"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var status in Model.StatusCodes)
                    {
                        <tr>
                            <td>@status.Code</td>
                            <td>@status.StatusName</td>
                            <td>
                                <a href="#" class="btn btn-ghost"><i data-lucide="pencil"></i> Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="placeholder">
                <i data-lucide="flag" class="icon-lg icon-faded"></i>
                <p>No status codes configured yet. Click "Add New Status Code" to get started.</p>
            </div>
        }
    </div>
</div>