@page
@model fixflow.web.Pages.Admin.TicketTypeCreateModel
@{
    ViewData["Title"] = "Add Ticket Type";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-folder"></i> Add Ticket Type</h1>
        <p class="page-subtitle">Create a new category for maintenance requests.</p>
    </div>

    <div class="card">
        <form method="post" class="form-stack">
            <div class="form-group">
                <label asp-for="Input.TypeName">Type Name</label>
                <input asp-for="Input.TypeName" type="text" />
            </div>

            <div class="form-actions">
                <button type="submit">Save Ticket Type</button>
                <a class="btn btn-secondary" asp-page="./TicketTypes">Back to Ticket Types</a>
            </div>
        </form>
    </div>
</div>