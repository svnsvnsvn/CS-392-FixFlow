@{
    var userName = User.Identity?.Name ?? "User";
    var initialChars = userName.Split(new[] { ' ', '.', '_' }, StringSplitOptions.RemoveEmptyEntries);
    var initials = initialChars.Length > 1
        ? string.Concat(initialChars[0][0], initialChars[1][0]).ToUpperInvariant()
        : userName.Substring(0, Math.Min(2, userName.Length)).ToUpperInvariant();
}
<aside class="app-sidebar">
    <div class="app-brand">
        <div class="app-brand-title">FixFlow</div>
        <div class="app-brand-subtitle">Maintenance System</div>
    </div>
    <div class="app-nav">
        <div class="app-nav-title">Main</div>
        <a class="app-nav-link" href="/Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
        @{
            var ticketsLabel = "My Tickets";
            if (User.IsInRole("Manager") || User.IsInRole("Admin") || User.IsInRole("Employee"))
            {
                ticketsLabel = "Tickets";
            }
        }
        <a class="app-nav-link" href="/Tickets/List"><i class="bi bi-clipboard-check"></i> @ticketsLabel</a>
        <a class="app-nav-link" href="/Account/Profile"><i class="bi bi-person-circle"></i> Account</a>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="app-nav">
            <div class="app-nav-title">Admin</div>
            <a class="app-nav-link" href="/Admin/Buildings"><i class="bi bi-building"></i> Buildings</a>
            <a class="app-nav-link" href="/Admin/TicketTypes"><i class="bi bi-folder"></i> Ticket Types</a>
            <a class="app-nav-link" href="/Admin/PriorityCodes"><i class="bi bi-exclamation-triangle"></i> Priority Codes</a>
            <a class="app-nav-link" href="/Admin/StatusCodes"><i class="bi bi-flag"></i> Status Codes</a>
            <a class="app-nav-link" href="/Admin/AdminUserTools"><i class="bi bi-people"></i> User Tool</a>
        </div>
    }

    <div class="app-sidebar-footer">
        <div class="app-user-row">
            <div class="app-user">
                <div class="app-user-avatar">@initials</div>
                <div>
                    <div class="app-user-name">@userName</div>
                    <div class="app-user-role">@User.FindFirst("role")?.Value</div>
                </div>
            </div>
            <form method="post" asp-page="/Dashboard" asp-page-handler="Logout" class="app-logout-form">
                <button type="submit" class="app-logout" aria-label="Logout" title="Logout">
                    <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                </button>
            </form>
        </div>
    </div>
</aside>
