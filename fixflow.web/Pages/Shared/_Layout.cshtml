@using fixflow.web.Data 
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@{
    var signedIn = SignInManager.IsSignedIn(User);
    var hideNav = (ViewData["HideNav"] as bool? ?? false) || signedIn;
    var fullBleed = hideNav;
    var landingPage = ViewData["LandingPage"] as bool? == true && !hideNav;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "FixFlow")</title>
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    @if (ViewData["OgTitle"] != null)
    {
        <meta property="og:title" content="@ViewData["OgTitle"]" />
        <meta property="og:description" content="@(ViewData["OgDescription"] ?? ViewData["MetaDescription"])" />
        <meta property="og:type" content="website" />
    }
    <link rel="icon" href="~/images/ff_logo.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/global.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/tickets.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="~/css/inspo.css" />
    <link rel="stylesheet" href="~/css/ref.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    @if (landingPage) { <link rel="stylesheet" href="~/css/about.css" /> }
    @RenderSection("Styles", required: false)
</head>
<body class="@(hideNav ? "layoutless" : "")@(ViewData["AuthPage"] as bool? == true ? " auth-page" : "")@(landingPage ? " landing-page" : "")">
    @if (landingPage)
    {
        <header class="landing-header">
            <nav class="landing-nav">
                <a class="landing-brand" href="/About" aria-label="FixFlow home">
                    <img class="landing-brand-logo" src="~/images/ff_logo.png" alt="" />
                    <span class="landing-brand-text">FixFlow</span>
                </a>
                <div class="landing-nav-links">
                    <a href="#how">How it works</a>
                    <a href="#roles">Who it's for</a>
                </div>
                <div class="landing-nav-actions">
                    <a class="landing-btn-login" href="/Account/Login">Log In <i class="bi bi-arrow-right" aria-hidden="true"></i></a>
                    <a class="landing-btn-create" href="/Account/NewUser"><i class="bi bi-plus-lg" aria-hidden="true"></i> Create Account</a>
                </div>
            </nav>
        </header>
    }
    else if (!hideNav)
    {
        <header class="site-header">
            <nav class="navbar">
                <a class="navbar-brand" href="/Account/Login">
                <img class="navbar-brand-logo" src="~/images/ff_logo.png" alt="" />
                FixFlow
            </a>
                <div class="navbar-links">
                    <a href="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Log In</a>
                    <a href="/Account/NewUser"><i class="bi bi-person-plus"></i> Create Account</a>
                    <a href="/About"><i class="bi bi-info-circle"></i> About Services</a>
                </div>
            </nav>
        </header>
    }

    <main class="page@(fullBleed ? " page--full" : "")">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>