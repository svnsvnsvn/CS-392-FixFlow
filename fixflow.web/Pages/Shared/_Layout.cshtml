@using Microsoft.AspNetCore.Identity
@using fixflow.web.Data
@inject SignInManager<AppUser> SignInManager
@{
    var signedIn = SignInManager.IsSignedIn(User);
    var hideNav = (ViewData["HideNav"] as bool? ?? false) || signedIn;
    var fullBleed = hideNav;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "FixFlow")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="@(hideNav ? "layoutless" : "")">
    @if (!hideNav)
    {
        <header class="site-header">
            <nav class="navbar">
                <a class="navbar-brand" href="/Account/Login">FixFlow</a>
                <div class="navbar-links">
                    <a href="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Log In</a>
                    <a href="/Account/NewUser"><i class="bi bi-person-plus"></i> Create Account</a>
                    <a href="/About"><i class="bi bi-info-circle"></i> About Services</a>
                </div>
            </nav>
        </header>
    }

    <main class="page@(fullBleed ? " page--full" : "")">
        @RenderBody()
    </main>
</body>
</html>