@using fixflow.web.Data 
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@{
    var signedIn = SignInManager.IsSignedIn(User);
    var hideNav = (ViewData["HideNav"] as bool? ?? false) || signedIn;
    var fullBleed = hideNav;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "FixFlow")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/global.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/tickets.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    @RenderSection("Styles", required: false)
</head>
<body class="@(hideNav ? "layoutless" : "")">
    @if (!hideNav)
    {
        <header class="site-header">
            <nav class="navbar">
                <a class="navbar-brand" href="/Account/Login">FixFlow</a>
                <div class="navbar-links">
                    <a href="/Account/Login"><i class="bi bi-box-arrow-in-right"></i> Log In</a>
                    <a href="/Account/NewUser"><i class="bi bi-person-plus"></i> Create Account</a>
                    <a href="/About"><i class="bi bi-info-circle"></i> About Services</a>
                </div>
            </nav>
        </header>
    }

    <main class="page@(fullBleed ? " page--full" : "")">
        @RenderBody()
    </main>

    <div class="announcement-modal" id="announcementModal" aria-hidden="true" hidden>
        <div class="announcement-card" role="dialog" aria-modal="true" aria-labelledby="announcementTitle">
            <div class="announcement-header">
                <h3 class="announcement-title" id="announcementTitle">Announcements</h3>
                <button class="btn btn-ghost" type="button" id="closeAnnouncements" aria-label="Close announcements">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="announcement-body">
                <div class="list-item">
                    <div class="list-title">Emergency request protocol</div>
                    <div class="list-meta">Use High priority for safety-related issues.</div>
                </div>
                <div class="list-item">
                    <div class="list-title">Maintenance hours</div>
                    <div class="list-meta">Standard service runs 8am - 6pm weekdays.</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const announcementModal = document.getElementById("announcementModal");
        const closeAnnouncements = document.getElementById("closeAnnouncements");

        const openAnnouncements = () => {
            if (!announcementModal) {
                return;
            }
            announcementModal.classList.add("active");
            announcementModal.setAttribute("aria-hidden", "false");
            announcementModal.removeAttribute("hidden");
        };

        const closeAnnouncementModal = () => {
            if (!announcementModal) {
                return;
            }
            announcementModal.classList.remove("active");
            announcementModal.setAttribute("aria-hidden", "true");
            announcementModal.setAttribute("hidden", "");
        };

        if (announcementModal && closeAnnouncements) {
            closeAnnouncements.addEventListener("click", closeAnnouncementModal);
            announcementModal.addEventListener("click", (event) => {
                if (event.target === announcementModal) {
                    closeAnnouncementModal();
                }
            });
        }

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
                closeAnnouncementModal();
            }
        });

        document.querySelectorAll("[data-announcements-open]").forEach((button) => {
            button.addEventListener("click", openAnnouncements);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>