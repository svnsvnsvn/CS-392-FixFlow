@page
@model fixflow.web.Pages.AboutModel
@{
    ViewData["Title"] = "About Services - FixFlow";
}

<div class="page-shell">
    <div class="page-header">
        <h1 class="page-title">About Our Services</h1>
        <p class="page-subtitle">Learn how FixFlow helps manage maintenance requests end-to-end.</p>
    </div>

    <div class="card">
        <p>
            FixFlow streamlines maintenance intake, assignment, and resolution for property teams and residents.
            Submit requests, track status updates, and collaborate with staff in one place.
        </p>
        <div class="divider"></div>
        <div class="page-shell">
            <div>
                <h2 class="page-title">What you can do</h2>
                <p class="page-subtitle">Key capabilities for residents, staff, and administrators.</p>
            </div>
            <div class="placeholder">
                Request tracking, priority management, internal notes, and reporting live here.
            </div>
        </div>
    </div>
</div>
