@page
@model fixflow.web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard - FixFlow";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
    /* Dashboard-specific styling */
    .dashboard-grid {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 0;
        min-height: 100vh;
        width: 100%;
    }

    .sidebar {
        background: linear-gradient(180deg, var(--accent) 0%, var(--accent-3) 100%);
        color: white;
        padding: 2rem 0;
        display: flex;
        flex-direction: column;
    }

    .sidebar-brand {
        padding: 0 1.5rem;
        margin-bottom: 2rem;
    }

    .brand-name {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .brand-subtitle {
        font-size: 0.875rem;
        opacity: 0.9;
    }

    .nav-section-title {
        padding: 0 1.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.7;
        margin-bottom: 0.5rem;
    }

    .nav-item {
        display: flex;
        align-items: center;
        padding: 0.875rem 1.5rem;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        border-left: 3px solid transparent;
    }

    .nav-item:hover {
        background: rgba(255, 255, 255, 0.1);
        border-left-color: white;
    }

    .nav-item.active {
        background: rgba(255, 255, 255, 0.15);
        border-left-color: white;
        font-weight: 600;
    }

    .nav-item .bi {
        font-size: 1.25rem;
        margin-right: 0.75rem;
        width: 1.5rem;
    }

    .sidebar-footer {
        margin-top: auto;
        padding: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .user-info {
        display: flex;
        align-items: center;
        margin-bottom: 1rem;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1.125rem;
        margin-right: 0.75rem;
    }

    .user-name {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .user-role {
        font-size: 0.75rem;
        opacity: 0.8;
    }

    .btn-logout {
        width: 100%;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 0.625rem;
        border-radius: var(--radius-sm);
    }

    .btn-logout:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: none;
        box-shadow: none;
    }

    .main-content {
        display: flex;
        flex-direction: column;
        background: var(--bg);
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 1.5rem 2rem 0;
    }

    .content-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text);
        margin: 0;
    }

    .content-actions {
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

    .content-area {
        padding: 1.5rem 2rem 2rem;
        flex: 1;
    }

    .welcome-section {
        background: var(--surface);
        color: var(--text);
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        margin-bottom: 1.5rem;
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

    .welcome-section::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        width: 6px;
        height: 100%;
        background: linear-gradient(180deg, var(--accent), var(--accent-2));
    }

    .welcome-title {
        font-size: 1.35rem;
        font-weight: 700;
        margin: 0 0 0.35rem;
        padding-left: 0.5rem;
    }

    .welcome-message {
        font-size: 0.95rem;
        color: var(--muted);
        margin: 0;
        padding-left: 0.5rem;
    }

    .table-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        margin: 0.75rem 0 1rem;
    }

    .table-toolbar .toolbar-group {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .table-toolbar .toolbar-spacer {
        flex: 1;
    }

    .search-input {
        min-width: 240px;
        background: #ffffff;
    }

    .toolbar-select {
        min-width: 150px;
        background: #ffffff;
    }

    .chip {
        border: 1px solid var(--line);
        background: #ffffff;
        color: var(--muted);
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .chip.active {
        color: var(--accent-3);
        border-color: rgba(42, 163, 164, 0.35);
        box-shadow: 0 6px 14px rgba(42, 163, 164, 0.12);
    }

    .icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid var(--line);
        color: var(--accent-3);
        background: #ffffff;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .icon-btn:hover {
        border-color: rgba(42, 163, 164, 0.4);
        box-shadow: 0 6px 14px rgba(42, 163, 164, 0.12);
        transform: translateY(-1px);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
    }

    .stat-label {
        color: var(--muted);
        font-size: 0.875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text);
    }

    .section {
        background: white;
        border-radius: var(--radius-lg);
        padding: 2rem;
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--line);
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }

    .tabs {
        display: inline-flex;
        gap: 0.4rem;
        margin-bottom: 1.25rem;
        padding: 4px;
        border-radius: 999px;
        background: var(--bg-2);
        border: 1px solid var(--line);
    }

    .tab {
        padding: 0.45rem 1rem;
        background: transparent;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 500;
        color: var(--muted);
        transition: all 0.3s ease;
        font-size: 0.9rem;
        font-family: var(--font-secondary);
    }

    .tab:hover {
        color: var(--accent);
    }

    .tab.active {
        color: var(--text);
        background: #ffffff;
        box-shadow: 0 6px 12px rgba(15, 23, 42, 0.08);
    }

    .table-container {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        background: #ffffff;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: var(--surface-2);
    }

    th {
        text-align: left;
        padding: 1rem;
        font-weight: 600;
        color: var(--muted);
        font-size: 0.875rem;
        text-transform: none;
        letter-spacing: 0.01em;
        border-bottom: 2px solid var(--line);
    }

    td {
        padding: 1rem;
        border-bottom: 1px solid var(--line);
        color: var(--text);
    }

    tbody tr:hover {
        background: var(--bg-2);
    }

    .ticket-id {
        font-weight: 700;
        color: var(--accent);
    }

    .badge {
        display: inline-block;
        padding: 0.375rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .badge-submitted { background: #dbeafe; color: #1e40af; }
    .badge-inreview { background: #fef3c7; color: #92400e; }
    .badge-assigned { background: #e0e7ff; color: #3730a3; }
    .badge-inprogress { background: #ddd6fe; color: #5b21b6; }
    .badge-onhold { background: #fecaca; color: #991b1b; }
    .badge-completed { background: #d1fae5; color: #065f46; }

    .priority-high { color: #dc2626; font-weight: 600; }
    .priority-medium { color: #f59e0b; font-weight: 600; }
    .priority-low { color: #059669; font-weight: 600; }

    .btn-view {
        background: var(--accent);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-sm);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-block;
        border: none;
        cursor: pointer;
    }

    .btn-view:hover {
        background: var(--accent-3);
        transform: translateY(-2px);
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--muted);
    }

    .empty-state .bi {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    @@media (max-width: 968px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .sidebar {
            padding: 1rem 0;
        }
    }

    </style>
</head>
<body class="dashboard-page">

<div class="dashboard-grid">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-name">FixFlow</div>
            <div class="brand-subtitle">Maintenance System</div>
        </div>

        <!-- Navigation based on role -->
        <nav>
            <div class="nav-section-title">Main</div>
            <a href="/Dashboard" class="nav-item active">
                <i class="bi bi-house-door"></i>
                Dashboard
            </a>

            @* Client-only navigation *@
            @if (Model.UserRole == "Client")
            {
            }

            @* Technician navigation *@
            @if (Model.UserRole == "Technician")
            {
                <a href="/Tickets/WorkQueue" class="nav-item">
                    <i class="bi bi-tools"></i>
                    Work Queue
                </a>
                <a href="/Tickets/MyAssignments" class="nav-item">
                    <i class="bi bi-list-check"></i>
                    My Assignments
                </a>
            }

            @* Manager navigation *@
            @if (Model.UserRole == "Manager")
            {
                <a href="/Tickets/All" class="nav-item">
                    <i class="bi bi-ticket-perforated"></i>
                    All Tickets
                </a>
                <a href="/Tickets/Unassigned" class="nav-item">
                    <i class="bi bi-hourglass-split"></i>
                    Unassigned
                </a>
                <a href="/Reports" class="nav-item">
                    <i class="bi bi-graph-up"></i>
                    Reports
                </a>
            }

            @* Admin navigation *@
            @if (Model.UserRole == "Admin")
            {
                <a href="/Admin/Users" class="nav-item">
                    <i class="bi bi-people"></i>
                    Manage Users
                </a>
                <a href="/Admin/Categories" class="nav-item">
                    <i class="bi bi-folder"></i>
                    Categories
                </a>
                <a href="/Admin/Reports" class="nav-item">
                    <i class="bi bi-graph-up"></i>
                    Reports
                </a>
                <a href="/Admin/Settings" class="nav-item">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>
            }
        </nav>

        <!-- User Info & Logout -->
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@Model.UserInitials</div>
                <div>
                    <div class="user-name">@Model.UserName</div>
                    <div class="user-role">@Model.UserRole</div>
                </div>
            </div>
            <form method="post" asp-page-handler="Logout">
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Content -->
        <div class="content-area">
            <div class="content-header">
                <h1 class="content-title">Dashboard</h1>
                <div class="content-actions">
                    <a href="/Tickets/Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i>
                        Create Ticket
                    </a>
                </div>
            </div>
            <!-- Welcome Section -->
            <div class="welcome-section">
                <h2 class="welcome-title">Welcome back, @Model.UserName!</h2>
                <p class="welcome-message">@Model.WelcomeMessage</p>
            </div>

            <!-- Stats (for Manager/Admin only) -->
            @if (Model.UserRole == "Manager" || Model.UserRole == "Admin")
            {
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-ticket-perforated"></i> Total Tickets</div>
                        <div class="stat-value">@Model.TotalTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-hourglass-split"></i> Pending</div>
                        <div class="stat-value">@Model.PendingTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-arrow-repeat"></i> In Progress</div>
                        <div class="stat-value">@Model.InProgressTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-check-circle"></i> Completed Today</div>
                        <div class="stat-value">@Model.CompletedToday</div>
                    </div>
                </div>
            }

            <!-- Tickets Section -->
            <div class="section">
                <div class="section-header">
                    <h3 class="section-title"><i class="bi bi-list-ul"></i> @Model.TicketsSectionTitle</h3>
                </div>

                <div class="table-toolbar">
                    <div class="toolbar-group">
                        <input class="search-input" type="search" placeholder="Search tickets" aria-label="Search tickets" />
                        <select class="toolbar-select" aria-label="Filter by status">
                            <option selected>All statuses</option>
                            <option>Submitted</option>
                            <option>In Progress</option>
                            <option>Assigned</option>
                            <option>Completed</option>
                        </select>
                        <select class="toolbar-select" aria-label="Filter by priority">
                            <option selected>All priorities</option>
                            <option>High</option>
                            <option>Medium</option>
                            <option>Low</option>
                        </select>
                        <select class="toolbar-select" aria-label="Sort tickets">
                            <option selected>Sort: newest</option>
                            <option>Sort: oldest</option>
                            <option>Sort: priority</option>
                            <option>Sort: status</option>
                        </select>
                    </div>
                    <div class="toolbar-spacer"></div>
                    <div class="toolbar-group">
                        <button class="chip active" type="button">All</button>
                        <button class="chip" type="button">Active</button>
                        <button class="chip" type="button">Completed</button>
                    </div>
                </div>

                <!-- Tickets Table -->
                <div class="table-container">
                    @if (Model.Tickets != null && Model.Tickets.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>Ticket ID</th>
                                    <th>Title</th>
                                    <th>Category</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    @if (Model.UserRole != "Client")
                                    {
                                        <th>Submitted By</th>
                                    }
                                    @if (Model.UserRole == "Technician")
                                    {
                                        <th>Due Date</th>
                                    }
                                    <th>Created</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.Tickets)
                                {
                                    <tr>
                                        <td><span class="ticket-id">#@ticket.Id</span></td>
                                        <td>@ticket.Title</td>
                                        <td>@ticket.Category</td>
                                        <td>
                                            <span class="priority-@ticket.Priority.ToLower()">
                                                @if (ticket.Priority == "High")
                                                {
                                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                                }
                                                @ticket.Priority
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge badge-@ticket.Status.ToLower().Replace(" ", "")">
                                                @ticket.Status
                                            </span>
                                        </td>
                                        @if (Model.UserRole != "Client")
                                        {
                                            <td>@ticket.SubmittedBy</td>
                                        }
                                        @if (Model.UserRole == "Technician")
                                        {
                                            <td>@(ticket.DueDate?.ToString("MMM dd") ?? "-")</td>
                                        }
                                        <td>@ticket.CreatedDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <a href="/Tickets/Details/@ticket.Id" class="icon-btn" title="View ticket #@ticket.Id" aria-label="View ticket #@ticket.Id">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox"></i>
                            <p>No tickets to display</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
</div>
</body>
</html>
