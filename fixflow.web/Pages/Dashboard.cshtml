@page
@model fixflow.web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard - FixFlow";
    ViewData["HideNav"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="dashboard-shell">
            <div class="content-header">
                <h1 class="content-title">Dashboard</h1>
                <div class="content-actions">
                    <button type="button" class="btn btn-secondary" data-announcements-open>
                        <i data-lucide="megaphone"></i>
                        Announcements
                    </button>
                    <a href="/Tickets/Create" class="btn btn-primary">
                        <i data-lucide="plus-circle"></i>
                        Create Ticket
                    </a>
                </div>
            </div>
            <div class="lead-panel">
                <h2 class="lead-title">Welcome back, @Model.UserName!</h2>
                <p class="lead-subtitle">@Model.WelcomeMessage</p>
            </div>

            <!-- Stats (for Manager/Admin only) -->
            @if (Model.UserRole == "Manager" || Model.UserRole == "Admin")
            {
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-label"><i data-lucide="ticket"></i> Total Tickets</div>
                        <div class="stat-value">@Model.TotalTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i data-lucide="clock"></i> Pending</div>
                        <div class="stat-value">@Model.PendingTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i data-lucide="refresh-cw"></i> In Progress</div>
                        <div class="stat-value">@Model.InProgressTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i data-lucide="check-circle"></i> Completed Today</div>
                        <div class="stat-value">@Model.CompletedToday</div>
                    </div>
                </div>
            }

            <div class="dashboard-layout">
                <section class="panel panel-span" id="schedule">
                    <div class="panel-header">
                        <div>
                            <h3 class="panel-title">Weekly View</h3>
                            <p class="panel-subtitle">Tap a day to reveal appointments.</p>
                        </div>
                        <div class="panel-actions">
                            <div class="week-controls">
                                <button class="week-button" type="button" id="weekPrev" aria-label="Previous week">
                                    <i data-lucide="chevron-left"></i>
                                </button>
                                <button class="week-button" type="button" id="weekNext" aria-label="Next week">
                                    <i data-lucide="chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="week-days" id="weekDays" data-week-start="@DateTime.Today.ToString("yyyy-MM-dd")">
                            @for (var i = 0; i < 7; i++)
                            {
                                var day = DateTime.Today.AddDays(i);
                                var isActive = i == 0;
                                <button class="day-button @(isActive ? "active" : "")" type="button" data-date="@day.ToString("yyyy-MM-dd")">
                                    <span class="day-label">@day.ToString("ddd")</span>
                                    <span class="day-number">@day.Day</span>
                                </button>
                            }
                        </div>
                        <div class="list-stack" id="appointmentList">
                            @foreach (var appointment in Model.UpcomingAppointments)
                            {
                                <div class="list-item" data-date="@appointment.When.ToString("yyyy-MM-dd")">
                                    <div class="list-title">@appointment.Title</div>
                                    <div class="list-meta">
                                        <span>@appointment.When.ToString("MMM dd · h:mm tt")</span>
                                        <span class="tag">@appointment.Status</span>
                                        <span>@appointment.Category</span>
                                    </div>
                                </div>
                            }
                            <div class="appointment-empty" id="appointmentEmpty">No appointments scheduled for this day.</div>
                        </div>
                    </div>
                </section>

                <section class="panel panel-activity" id="activity">
                    <div class="panel-header">
                        <div>
                            <h3 class="panel-title">Recent Activity</h3>
                            <p class="panel-subtitle">Latest ticket updates across your queue.</p>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="list-stack">
                            @foreach (var activity in Model.RecentActivity)
                            {
                                <div class="list-item">
                                    <div class="list-title">@activity.Title</div>
                                    <div class="list-meta">
                                        <span>@activity.TimeStamp.ToString("MMM dd · h:mm tt")</span>
                                        <span class="tag">@activity.Status</span>
                                        <span>@activity.Meta</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </section>

                <section class="panel panel-tickets" id="tickets">
                    <div class="panel-header">
                        <div>
                            <h3 class="panel-title">@Model.TicketsSectionTitle Snapshot</h3>
                            <p class="panel-subtitle">Top 10 most recently updated tickets.</p>
                        </div>
                        <div class="panel-actions">
                            <a href="@Model.TicketsViewAllUrl" class="btn btn-secondary">View all</a>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="filter-bar">
                            <div class="filter-group">
                                <input class="filter-input" type="search" placeholder="Search tickets" aria-label="Search tickets" />
                                <select class="filter-select" aria-label="Filter by status">
                                    <option selected>All statuses</option>
                                    <option>Submitted</option>
                                    <option>In Progress</option>
                                    <option>Assigned</option>
                                    <option>Completed</option>
                                </select>
                                <select class="filter-select" aria-label="Filter by priority">
                                    <option selected>All priorities</option>
                                    <option>High</option>
                                    <option>Medium</option>
                                    <option>Low</option>
                                </select>
                                <select class="filter-select" aria-label="Sort tickets">
                                    <option selected>Sort: last updated</option>
                                    <option>Sort: newest</option>
                                    <option>Sort: oldest</option>
                                    <option>Sort: priority</option>
                                </select>
                            </div>
                            <div class="filter-spacer"></div>
                            <div class="filter-group">
                                <button class="btn btn-ghost" type="button">Clear filters</button>
                            </div>
                        </div>

                        <div class="table-container">
                            @if (Model.RecentTickets != null && Model.RecentTickets.Any())
                            {
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Ticket ID</th>
                                            <th>Title</th>
                                            <th>Category</th>
                                            <th>Priority</th>
                                            <th>Status</th>
                                            @if (Model.UserRole != "Client")
                                            {
                                                <th>Submitted By</th>
                                            }
                                            @if (Model.UserRole == "Technician")
                                            {
                                                <th>Due Date</th>
                                            }
                                            <th>Created</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ticket in Model.RecentTickets)
                                        {
                                            <tr>
                                                <td><span class="ticket-id">#@ticket.Id</span></td>
                                                <td>@ticket.Title</td>
                                                <td>@ticket.Category</td>
                                                <td>
                                                    <span class="priority-text @ticket.Priority.ToLower()">
                                                        @ticket.Priority
                                                    </span>
                                                </td>
                                                <td>
                                                    @{
                                                        var statusClass = ticket.Status.ToLower().Replace(" ", "");
                                                        var statusIcon = statusClass switch
                                                        {
                                                            "submitted" => "circle",
                                                            "inreview" => "clock",
                                                            "assigned" => "user-check",
                                                            "inprogress" => "loader",
                                                            "onhold" => "pause-circle",
                                                            "completed" => "check-circle",
                                                            "cancelled" => "x-circle",
                                                            _ => "circle-dot"
                                                        };
                                                    }
                                                    <i class="status-icon @statusClass" data-lucide="@statusIcon" title="@ticket.Status"></i>
                                                </td>
                                                @if (Model.UserRole != "Client")
                                                {
                                                    <td>@ticket.SubmittedBy</td>
                                                }
                                                @if (Model.UserRole == "Technician")
                                                {
                                                    <td>@(ticket.DueDate?.ToString("MMM dd") ?? "-")</td>
                                                }
                                                <td>@ticket.CreatedDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    <a href="/Tickets/Details/@ticket.Id" class="icon-btn" title="View ticket #@ticket.Id" aria-label="View ticket #@ticket.Id">
                                                        <i data-lucide="eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <i data-lucide="inbox"></i>
                                    <p>No tickets to display</p>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>
</div>

<script>
    const weekDays = document.getElementById("weekDays");
    const appointmentList = document.getElementById("appointmentList");
    const appointmentEmpty = document.getElementById("appointmentEmpty");
    const weekPrev = document.getElementById("weekPrev");
    const weekNext = document.getElementById("weekNext");
    let currentWeekStart = new Date();

    const updateAppointments = (date) => {
        if (!appointmentList || !appointmentEmpty) {
            return;
        }

        let matches = 0;
        appointmentList.querySelectorAll(".list-item").forEach((item) => {
            const itemDate = item.getAttribute("data-date");
            const show = itemDate === date;
            item.style.display = show ? "flex" : "none";
            if (show) {
                matches += 1;
            }
        });

        appointmentEmpty.style.display = matches ? "none" : "block";
    };

    const updateWeekButtons = (startDate) => {
        currentWeekStart = new Date(startDate);
        if (!weekDays) {
            return;
        }

        const dayButtons = Array.from(weekDays.querySelectorAll(".day-button"));
        dayButtons.forEach((button, index) => {
            const date = new Date(startDate);
            date.setDate(date.getDate() + index);
            const iso = date.toISOString().slice(0, 10);
            button.setAttribute("data-date", iso);
            button.querySelector(".day-label").textContent = date.toLocaleDateString(undefined, { weekday: "short" });
            button.querySelector(".day-number").textContent = date.getDate();
        });

        dayButtons.forEach((button, index) => {
            button.classList.toggle("active", index === 0);
        });

        updateAppointments(dayButtons[0].getAttribute("data-date"));
    };

    if (weekDays) {
        weekDays.addEventListener("click", (event) => {
            const button = event.target.closest(".day-button");
            if (!button) {
                return;
            }
            weekDays.querySelectorAll(".day-button").forEach((item) => item.classList.remove("active"));
            button.classList.add("active");
            updateAppointments(button.getAttribute("data-date"));
        });
    }

    if (weekPrev && weekNext) {
        const changeWeek = (direction) => {
            const startDate = new Date(currentWeekStart);
            startDate.setDate(startDate.getDate() + direction * 7);
            updateWeekButtons(startDate);
        };

        weekPrev.addEventListener("click", () => changeWeek(-1));
        weekNext.addEventListener("click", () => changeWeek(1));
    }

    if (weekDays) {
        const firstDate = weekDays.querySelector(".day-button")?.getAttribute("data-date");
        if (firstDate) {
            currentWeekStart = new Date(firstDate);
            updateAppointments(firstDate);
        }
    }
</script>
