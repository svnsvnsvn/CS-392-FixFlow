@page
@model fixflow.web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard - FixFlow";
    ViewData["HideNav"] = true;
}

<style>
    /* Dashboard-specific styling */
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 0.75rem;
    }

    .content-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text);
        margin: 0;
    }

    .content-actions {
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

    .dashboard-shell {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .lead-panel {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        box-shadow: none;
    }

    .lead-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0 0 0.35rem;
    }

    .lead-subtitle {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
    }

    .dashboard-layout {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
        gap: 12px;
        align-items: start;
    }

    .panel-span {
        grid-column: 1 / -1;
    }

    .panel-tickets {
        grid-column: 1 / 2;
    }

    .panel-activity {
        grid-column: 2 / 3;
        align-self: start;
    }

    .panel {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 6px;
        box-shadow: none;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        padding: 1rem 1.25rem 0.75rem;
        border-bottom: 1px solid var(--line);
    }

    .panel-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0;
    }

    .panel-subtitle {
        margin: 0.25rem 0 0;
        font-size: 0.85rem;
        color: var(--muted);
    }

    .panel-actions {
        display: inline-flex;
        gap: 8px;
        align-items: center;
    }

    .panel-body {
        padding: 0.9rem 1.25rem 1.1rem;
    }

    .week-controls {
        display: inline-flex;
        gap: 8px;
        align-items: center;
    }

    .week-button {
        border: 1px solid var(--line);
        background: #ffffff;
        border-radius: 6px;
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        cursor: pointer;
    }

    .week-days {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 8px;
        margin-bottom: 1rem;
    }

    .day-button {
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 0.5rem;
        background: #ffffff;
        text-align: left;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 0.8rem;
        color: var(--muted);
    }

    .day-button.active {
        border-color: rgba(42, 163, 164, 0.4);
        box-shadow: 0 6px 14px rgba(42, 163, 164, 0.12);
        color: var(--text);
    }

    .day-label {
        text-transform: uppercase;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
    }

    .day-number {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
    }

    .appointment-empty {
        padding: 0.75rem 0.9rem;
        border: 1px dashed var(--line);
        border-radius: 6px;
        color: var(--muted);
        font-size: 0.85rem;
    }

    .list-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .list-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 0.75rem 0.9rem;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: var(--surface-2);
    }

    .list-title {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .list-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        color: var(--muted);
        font-size: 0.8rem;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 2px 8px;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted);
        background: #ffffff;
    }


    .icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 6px;
        border: 1px solid var(--line);
        color: var(--accent-3);
        background: #ffffff;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .icon-btn:hover {
        border-color: rgba(42, 163, 164, 0.4);
        box-shadow: 0 6px 14px rgba(42, 163, 164, 0.12);
        transform: translateY(-1px);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 6px;
        border: 1px solid var(--line);
        box-shadow: none;
    }

    .stat-label {
        color: var(--muted);
        font-size: 0.875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text);
    }

    .section {
        background: white;
        border-radius: 6px;
        padding: 2rem;
        border: 1px solid var(--line);
        box-shadow: none;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--line);
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }

    .tabs {
        display: inline-flex;
        gap: 0.4rem;
        margin-bottom: 1.25rem;
        padding: 4px;
        border-radius: 999px;
        background: var(--bg-2);
        border: 1px solid var(--line);
    }

    .tab {
        padding: 0.45rem 1rem;
        background: transparent;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 500;
        color: var(--muted);
        transition: all 0.3s ease;
        font-size: 0.9rem;
        font-family: var(--font-secondary);
    }

    .tab:hover {
        color: var(--accent);
    }

    .tab.active {
        color: var(--text);
        background: #ffffff;
        box-shadow: 0 6px 12px rgba(15, 23, 42, 0.08);
    }

    .table-container {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: #ffffff;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: var(--surface-2);
    }

    th {
        text-align: left;
        padding: 1rem;
        font-weight: 600;
        color: var(--muted);
        font-size: 0.875rem;
        text-transform: none;
        letter-spacing: 0.01em;
        border-bottom: 2px solid var(--line);
    }

    td {
        padding: 1rem;
        border-bottom: 1px solid var(--line);
        color: var(--text);
    }

    tbody tr:hover {
        background: var(--bg-2);
    }

    .ticket-id {
        font-weight: 700;
        color: var(--accent);
    }

    .badge-submitted { background: #dbeafe; color: #1e40af; }
    .badge-inreview { background: #fef3c7; color: #92400e; }
    .badge-assigned { background: #e0e7ff; color: #3730a3; }
    .badge-inprogress { background: #ddd6fe; color: #5b21b6; }
    .badge-onhold { background: #fecaca; color: #991b1b; }
    .badge-completed { background: #d1fae5; color: #065f46; }

    .priority-high { color: #dc2626; font-weight: 600; }
    .priority-medium { color: #f59e0b; font-weight: 600; }
    .priority-low { color: #059669; font-weight: 600; }

    .btn-view {
        background: var(--accent);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-sm);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-block;
        border: none;
        cursor: pointer;
    }

    .btn-view:hover {
        background: var(--accent-3);
        transform: translateY(-2px);
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--muted);
    }

    .empty-state .bi {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    @@media (max-width: 968px) {
        .dashboard-layout {
            grid-template-columns: 1fr;
        }

        .panel-span,
        .panel-tickets,
        .panel-activity {
            grid-column: 1 / -1;
        }

        .week-days {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    </style>

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="dashboard-shell">
            <div class="content-header">
                <h1 class="content-title">Dashboard</h1>
                <div class="content-actions">
                    <button type="button" class="btn btn-secondary" data-announcements-open>
                        <i class="bi bi-megaphone"></i>
                        Announcements
                    </button>
                    <a href="/Tickets/Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i>
                        Create Ticket
                    </a>
                </div>
            </div>
            <div class="lead-panel">
                <h2 class="lead-title">Welcome back, @Model.UserName!</h2>
                <p class="lead-subtitle">@Model.WelcomeMessage</p>
            </div>

            <!-- Stats (for Manager/Admin only) -->
            @if (Model.UserRole == "Manager" || Model.UserRole == "Admin")
            {
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-ticket-perforated"></i> Total Tickets</div>
                        <div class="stat-value">@Model.TotalTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-hourglass-split"></i> Pending</div>
                        <div class="stat-value">@Model.PendingTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-arrow-repeat"></i> In Progress</div>
                        <div class="stat-value">@Model.InProgressTickets</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label"><i class="bi bi-check-circle"></i> Completed Today</div>
                        <div class="stat-value">@Model.CompletedToday</div>
                    </div>
                </div>
            }

            <div class="dashboard-layout">
                <section class="panel panel-span" id="schedule">
                    <div class="panel-header">
                        <div>
                            <h3 class="panel-title">Weekly View</h3>
                            <p class="panel-subtitle">Tap a day to reveal appointments.</p>
                        </div>
                        <div class="panel-actions">
                            <div class="week-controls">
                                <button class="week-button" type="button" id="weekPrev" aria-label="Previous week">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <button class="week-button" type="button" id="weekNext" aria-label="Next week">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="week-days" id="weekDays" data-week-start="@DateTime.Today.ToString("yyyy-MM-dd")">
                            @for (var i = 0; i < 7; i++)
                            {
                                var day = DateTime.Today.AddDays(i);
                                var isActive = i == 0;
                                <button class="day-button @(isActive ? "active" : "")" type="button" data-date="@day.ToString("yyyy-MM-dd")">
                                    <span class="day-label">@day.ToString("ddd")</span>
                                    <span class="day-number">@day.Day</span>
                                </button>
                            }
                        </div>
                        <div class="list-stack" id="appointmentList">
                            @foreach (var appointment in Model.UpcomingAppointments)
                            {
                                <div class="list-item" data-date="@appointment.When.ToString("yyyy-MM-dd")">
                                    <div class="list-title">@appointment.Title</div>
                                    <div class="list-meta">
                                        <span>@appointment.When.ToString("MMM dd · h:mm tt")</span>
                                        <span class="tag">@appointment.Status</span>
                                        <span>@appointment.Category</span>
                                    </div>
                                </div>
                            }
                            <div class="appointment-empty" id="appointmentEmpty">No appointments scheduled for this day.</div>
                        </div>
                    </div>
                </section>

                <section class="panel panel-activity" id="activity">
                    <div class="panel-header">
                        <div>
                            <h3 class="panel-title">Recent Activity</h3>
                            <p class="panel-subtitle">Latest ticket updates across your queue.</p>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="list-stack">
                            @foreach (var activity in Model.RecentActivity)
                            {
                                <div class="list-item">
                                    <div class="list-title">@activity.Title</div>
                                    <div class="list-meta">
                                        <span>@activity.TimeStamp.ToString("MMM dd · h:mm tt")</span>
                                        <span class="tag">@activity.Status</span>
                                        <span>@activity.Meta</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </section>

                <section class="panel panel-tickets" id="tickets">
                    <div class="panel-header">
                        <div>
                            <h3 class="panel-title">@Model.TicketsSectionTitle Snapshot</h3>
                            <p class="panel-subtitle">Top 10 most recently updated tickets.</p>
                        </div>
                        <div class="panel-actions">
                            <a href="@Model.TicketsViewAllUrl" class="btn btn-secondary">View all</a>
                        </div>
                    </div>
                    <div class="panel-body">
                        <div class="filter-bar">
                            <div class="filter-group">
                                <input class="filter-input" type="search" placeholder="Search tickets" aria-label="Search tickets" />
                                <select class="filter-select" aria-label="Filter by status">
                                    <option selected>All statuses</option>
                                    <option>Submitted</option>
                                    <option>In Progress</option>
                                    <option>Assigned</option>
                                    <option>Completed</option>
                                </select>
                                <select class="filter-select" aria-label="Filter by priority">
                                    <option selected>All priorities</option>
                                    <option>High</option>
                                    <option>Medium</option>
                                    <option>Low</option>
                                </select>
                                <select class="filter-select" aria-label="Sort tickets">
                                    <option selected>Sort: last updated</option>
                                    <option>Sort: newest</option>
                                    <option>Sort: oldest</option>
                                    <option>Sort: priority</option>
                                </select>
                            </div>
                            <div class="filter-spacer"></div>
                            <div class="filter-group">
                                <button class="btn btn-ghost" type="button">Clear filters</button>
                            </div>
                        </div>

                        <div class="table-container">
                            @if (Model.RecentTickets != null && Model.RecentTickets.Any())
                            {
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Ticket ID</th>
                                            <th>Title</th>
                                            <th>Category</th>
                                            <th>Priority</th>
                                            <th>Status</th>
                                            @if (Model.UserRole != "Client")
                                            {
                                                <th>Submitted By</th>
                                            }
                                            @if (Model.UserRole == "Technician")
                                            {
                                                <th>Due Date</th>
                                            }
                                            <th>Created</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ticket in Model.RecentTickets)
                                        {
                                            <tr>
                                                <td><span class="ticket-id">#@ticket.Id</span></td>
                                                <td>@ticket.Title</td>
                                                <td>@ticket.Category</td>
                                                <td>
                                                    <span class="priority-@ticket.Priority.ToLower()">
                                                        @if (ticket.Priority == "High")
                                                        {
                                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                                        }
                                                        @ticket.Priority
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge badge-@ticket.Status.ToLower().Replace(" ", "")">
                                                        @ticket.Status
                                                    </span>
                                                </td>
                                                @if (Model.UserRole != "Client")
                                                {
                                                    <td>@ticket.SubmittedBy</td>
                                                }
                                                @if (Model.UserRole == "Technician")
                                                {
                                                    <td>@(ticket.DueDate?.ToString("MMM dd") ?? "-")</td>
                                                }
                                                <td>@ticket.CreatedDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    <a href="/Tickets/Details/@ticket.Id" class="icon-btn" title="View ticket #@ticket.Id" aria-label="View ticket #@ticket.Id">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <i class="bi bi-inbox"></i>
                                    <p>No tickets to display</p>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>
</div>

<script>
    const weekDays = document.getElementById("weekDays");
    const appointmentList = document.getElementById("appointmentList");
    const appointmentEmpty = document.getElementById("appointmentEmpty");
    const weekPrev = document.getElementById("weekPrev");
    const weekNext = document.getElementById("weekNext");
    let currentWeekStart = new Date();

    const updateAppointments = (date) => {
        if (!appointmentList || !appointmentEmpty) {
            return;
        }

        let matches = 0;
        appointmentList.querySelectorAll(".list-item").forEach((item) => {
            const itemDate = item.getAttribute("data-date");
            const show = itemDate === date;
            item.style.display = show ? "flex" : "none";
            if (show) {
                matches += 1;
            }
        });

        appointmentEmpty.style.display = matches ? "none" : "block";
    };

    const updateWeekButtons = (startDate) => {
        currentWeekStart = new Date(startDate);
        if (!weekDays) {
            return;
        }

        const dayButtons = Array.from(weekDays.querySelectorAll(".day-button"));
        dayButtons.forEach((button, index) => {
            const date = new Date(startDate);
            date.setDate(date.getDate() + index);
            const iso = date.toISOString().slice(0, 10);
            button.setAttribute("data-date", iso);
            button.querySelector(".day-label").textContent = date.toLocaleDateString(undefined, { weekday: "short" });
            button.querySelector(".day-number").textContent = date.getDate();
        });

        dayButtons.forEach((button, index) => {
            button.classList.toggle("active", index === 0);
        });

        updateAppointments(dayButtons[0].getAttribute("data-date"));
    };

    if (weekDays) {
        weekDays.addEventListener("click", (event) => {
            const button = event.target.closest(".day-button");
            if (!button) {
                return;
            }
            weekDays.querySelectorAll(".day-button").forEach((item) => item.classList.remove("active"));
            button.classList.add("active");
            updateAppointments(button.getAttribute("data-date"));
        });
    }

    if (weekPrev && weekNext) {
        const changeWeek = (direction) => {
            const startDate = new Date(currentWeekStart);
            startDate.setDate(startDate.getDate() + direction * 7);
            updateWeekButtons(startDate);
        };

        weekPrev.addEventListener("click", () => changeWeek(-1));
        weekNext.addEventListener("click", () => changeWeek(1));
    }

    if (weekDays) {
        const firstDate = weekDays.querySelector(".day-button")?.getAttribute("data-date");
        if (firstDate) {
            currentWeekStart = new Date(firstDate);
            updateAppointments(firstDate);
        }
    }
</script>
