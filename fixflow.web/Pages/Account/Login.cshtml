@page
@model fixflow.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login - FixFlow";
    Layout = "_Layout";
}

<div class="auth-shell">
    <div class="login-container">
        <div class="logo-section">
            <div class="logo-text">FixFlow</div>
            <div class="logo-subtitle">Maintenance Request System</div>
        </div>

        @if (Model.LoginFailed)
        {
            <div class="error-message">
                <span class="error-icon">⚠️</span>
                <span>Invalid username or password. Please try again.</span>
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="username">Username</label>
                <input name="userName"
                       type="text"
                       id="username"
                       placeholder="Enter your username"
                       autocomplete="username"
                       required />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input name="password"
                       type="password"
                       id="password"
                       placeholder="Enter your password"
                       autocomplete="current-password"
                       required />
            </div>

            <button type="submit" class="btn-login">Sign In</button>
        </form>

        <div class="divider"></div>

        <div class="footer-text">
            <a asp-page="./NewUser">Create account</a>
        </div>

        <div class="footer-text">
            Secure access to your maintenance dashboard
        </div>
    </div>
</div>
