@page
@model fixflow.web.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "User Profile";
    ViewData["HideNav"] = true;
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="app-main">
        <div class="page-shell">
            <div class="page-header">
                <h1 class="page-title">User Profile</h1>
                <p class="page-subtitle">Update your contact details and password settings.</p>
            </div>

            <div class="card">
                <form method="post" asp-page-handler="UpdateProfile" class="form-stack p-6">
                    <h2 class="text-lg font-semibold mb-4">Contact Information</h2>
                    
                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="ProfileInput.UserName">Username</label>
                            <input asp-for="ProfileInput.UserName" />
                        </div>
                        <div class="form-group">
                            <label asp-for="ProfileInput.FirstName">First Name</label>
                            <input asp-for="ProfileInput.FirstName" />
                        </div>

                        <div class="form-group">
                            <label asp-for="ProfileInput.LastName">Last Name</label>
                            <input asp-for="ProfileInput.LastName" />
                        </div>

                        <div class="form-group">
                            <label asp-for="ProfileInput.Email">Email</label>
                            <input asp-for="ProfileInput.Email" />
                        </div>

                        <div class="form-group">
                            <label asp-for="ProfileInput.PhoneNumber">Phone Number</label>
                            <input asp-for="ProfileInput.PhoneNumber" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Profile</button>
                    </div>
                </form>
            </div>

            <div class="card">
                <form method="post" asp-page-handler="ChangePassword" asp-route-userId="@Model.PasswordInput.UserId" asp-route-token="@Model.PasswordInput.SecurityTokenStash" class="form-stack p-6">
                    <h2 class="text-lg font-semibold mb-1">Password</h2>
                    <p class="page-subtitle mb-4">Keep your account secure with a strong password.</p>

                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="PasswordInput.CurrentPassword">Current Password</label>
                            @if (Model.RequireCurrentPassword)
                            {
                                <input type="password" asp-for="PasswordInput.CurrentPassword" />
                            }
                            else
                            {
                                <input asp-for="PasswordInput.CurrentPassword" disabled />
                            }
                        </div>
                        <div class="form-group">
                            <label asp-for="PasswordInput.NewPassword">New Password</label>
                            <input type="password" asp-for="PasswordInput.NewPassword" />
                        </div>
                        <div class="form-group">
                            <label asp-for="PasswordInput.VerifyPassword">Verify Password</label>
                            <input type="password" asp-for="PasswordInput.VerifyPassword" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Password</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>