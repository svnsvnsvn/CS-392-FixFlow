@page
@model fixflow.web.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "User Profile";
    ViewData["HideNav"] = true;
    ViewData["ActiveNav"] = "Account";
    ViewData["BreadcrumbPath"] = "Account";
    ViewData["BreadcrumbTitle"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" />
}

<div class="app-shell">
    @await Html.PartialAsync("_AppSidebar")

    <main class="main ref-main">
        @await Html.PartialAsync("_Topbar")
        <div class="ref-page">
            <p class="ph-s">Update your contact details and password settings.</p>

            @if (TempData["StatusMessage"] is string status && !string.IsNullOrEmpty(status))
            {
                <p class="ph-s mb20" style="color:#065f46;" role="status">@status</p>
            }

            <div class="card mb20">
                <div class="ch">
                    <span class="ct"><i class="bi bi-building" aria-hidden="true"></i> Residence on file</span>
                </div>
                <div class="cb">
                    <div class="fgrid">
                        <div class="fg">
                            <label class="flbl">Building / location</label>
                            <input class="finp" value="@Model.ResidenceBuildingLabel" readonly disabled />
                        </div>
                        <div class="fg">
                            <label class="flbl">Unit</label>
                            <input class="finp" value="@Model.ResidenceUnitLabel" readonly disabled />
                        </div>
                    </div>
                    <p class="ph-s text-muted">Used as the default on maintenance requests. Contact your property office if this needs to be updated.</p>
                </div>
            </div>

            <div class="card mb20">
                <div class="ch">
                    <span class="ct"><i class="bi bi-person-badge" aria-hidden="true"></i> Contact Information</span>
                </div>
                <div class="cb">
                    <form method="post" asp-page-handler="UpdateProfile">
                        <div class="fgrid">
                            <div class="fg">
                                <label class="flbl" asp-for="ProfileInput.UserName">Username</label>
                                <input class="finp" asp-for="ProfileInput.UserName" />
                                <span asp-validation-for="ProfileInput.UserName" class="text-danger"></span>
                            </div>
                            <div class="fg">
                                <label class="flbl" asp-for="ProfileInput.FirstName">First Name</label>
                                <input class="finp" asp-for="ProfileInput.FirstName" />
                                <span asp-validation-for="ProfileInput.FirstName" class="text-danger"></span>
                            </div>
                            <div class="fg">
                                <label class="flbl" asp-for="ProfileInput.LastName">Last Name</label>
                                <input class="finp" asp-for="ProfileInput.LastName" />
                                <span asp-validation-for="ProfileInput.LastName" class="text-danger"></span>
                            </div>
                            <div class="fg">
                                <label class="flbl" asp-for="ProfileInput.Email">Email</label>
                                <input class="finp" asp-for="ProfileInput.Email" type="email" />
                                <span asp-validation-for="ProfileInput.Email" class="text-danger"></span>
                            </div>
                            <div class="fg fg-full">
                                <label class="flbl" asp-for="ProfileInput.PhoneNumber">Phone Number</label>
                                <input class="finp" asp-for="ProfileInput.PhoneNumber" type="tel" />
                                <span asp-validation-for="ProfileInput.PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="ph cb-actions">
                            <button type="submit" class="btn btn-p">
                                <i class="bi bi-save" aria-hidden="true"></i> Save Profile
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mb20">
                <div class="ch">
                    <span class="ct"><i class="bi bi-shield-lock" aria-hidden="true"></i> Password</span>
                </div>
                <div class="cb">
                    <p class="ph-s">Keep your account secure with a strong password.</p>
                    <form method="post" asp-page-handler="ChangePassword" asp-route-userId="@Model.PasswordInput.UserId" asp-route-token="@Model.PasswordInput.SecurityTokenStash">
                        <div class="fgrid">
                            <div class="fg">
                                <label class="flbl" asp-for="PasswordInput.CurrentPassword">Current Password</label>
                                @if (Model.RequireCurrentPassword)
                                {
                                    <input class="finp" type="password" asp-for="PasswordInput.CurrentPassword" />
                                }
                                else
                                {
                                    <input class="finp" asp-for="PasswordInput.CurrentPassword" disabled placeholder="Not required for this update" />
                                }
                                <span asp-validation-for="PasswordInput.CurrentPassword" class="text-danger"></span>
                            </div>
                            <div class="fg">
                                <label class="flbl" asp-for="PasswordInput.NewPassword">New Password</label>
                                <input class="finp" type="password" asp-for="PasswordInput.NewPassword" />
                                <span asp-validation-for="PasswordInput.NewPassword" class="text-danger"></span>
                            </div>
                            <div class="fg fg-full">
                                <label class="flbl" asp-for="PasswordInput.VerifyPassword">Verify Password</label>
                                <input class="finp" type="password" asp-for="PasswordInput.VerifyPassword" />
                                <span asp-validation-for="PasswordInput.VerifyPassword" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="ph cb-actions">
                            <button type="submit" class="btn btn-p">
                                <i class="bi bi-key" aria-hidden="true"></i> Update Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
